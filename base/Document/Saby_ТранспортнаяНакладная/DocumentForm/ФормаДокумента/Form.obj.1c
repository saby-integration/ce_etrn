#Область КлючиСтрок

&НаСервере
Процедура МаксимальныеКлючиСтрок()
	
	ИмяКолонки = "КлючСтроки";
	
	// Грузы
	Если Объект.Грузы.Количество() = 0 Тогда
		ЭтаФорма.МаксимальныйКлючСтроки_Грузы = 0;		
	Иначе 	
		
		СписокКлючей = Новый СписокЗначений;	
		СписокКлючей.ЗагрузитьЗначения(Объект.Грузы.Выгрузить(, ИмяКолонки).ВыгрузитьКолонку(ИмяКолонки)); 
		
		СписокКлючей.СортироватьПоЗначению(НаправлениеСортировки.Убыв);   
				
		ЭтаФорма.МаксимальныйКлючСтроки_Грузы = СписокКлючей[0].Значение;
		
	КонецЕсли;
		
	// Отметки
	Если Объект.Отметки.Количество() = 0 Тогда
		ЭтаФорма.МаксимальныйКлючСтроки_Отметки = 0;		
	Иначе 	
		
		СписокКлючей = Новый СписокЗначений; 		
		СписокКлючей.ЗагрузитьЗначения(Объект.Отметки.Выгрузить(, ИмяКолонки).ВыгрузитьКолонку(ИмяКолонки));
		
		СписокКлючей.СортироватьПоЗначению(НаправлениеСортировки.Убыв);   
				
		ЭтаФорма.МаксимальныйКлючСтроки_Отметки = СписокКлючей[0].Значение;
		
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Функция НовыйКлючСтроки(ИмяТЧ)
	
	// Если в табл. части уже присутствуют строки, то новое «свободное» значение ключа
	// рассчитывается от максимального существующего значения.
			
	Если ИмяТЧ = "Грузы" Тогда 
		
		// Если Объект.Грузы.Количество() > 1 Тогда
			МаксимальныйКлючСтроки_Грузы = МаксимальныйКлючСтроки_Грузы + 1;			
		// КонецЕсли;
		
		Возврат МаксимальныйКлючСтроки_Грузы;
			
	Иначе        
		
		// Отметки 
		// Если Объект.Отметки.Количество() > 1 Тогда			
			МаксимальныйКлючСтроки_Отметки = МаксимальныйКлючСтроки_Отметки + 1;			
		// КонецЕсли;
		
		Возврат МаксимальныйКлючСтроки_Отметки;
		
	КонецЕсли;
	
КонецФункции

#КонецОбласти

&НаКлиенте
Процедура УстановитьОтборыПоТаблицам()

	// Контактная информация
	ОтборИнформацииПоКонтактнымДанным("КонтактныеДанные",            "Отправитель");
	ОтборИнформацииПоКонтактнымДанным("КонтактныеДанные_Получатель", "Получатель");
	ОтборИнформацииПоКонтактнымДанным("КонтактныеДанные_Перевозчик", "Перевозчик");
	ОтборИнформацииПоКонтактнымДанным("КонтактныеДанные_Отгрузка",   "Отгрузчик");
	ОтборИнформацииПоКонтактнымДанным("КонтактныеДанные_Владелец",   "ВладелецОбъекта");
	
	// Грузы. Связанные таблицы 
	Грузы_УстановитьОтборПоВсемСвязаннымТаблицам();
	
	// Отметки 
	ОтборОтметокПоТипу("Отметки",          ТипОтметок_Погрузка);	
	ОтборОтметокПоТипу("Отметки_Выгрузка", ТипОтметок_Выгрузка);
	
	// Отметки. Связанные таблицы
	
КонецПроцедуры

// Заполнение реквизитов формы при изменение, связанной информации
// или первоначальной инициализации формы
&НаСервере
Процедура ЗаполнитьРасчетныеРеквизиты()
	
	Если ЗначениеЗаполнено(Объект.Отправитель) Тогда 
		ЭтаФорма.Грузоотправитель_Грузополучатель = (Объект.Получатель = Объект.Отправитель);
	КонецЕсли;
	
	ЭтаФорма.Грузоотправитель_ОсуществляетОтгрузку = (Объект.Отправитель = Объект.Отгрузчик);
 
	ЭтаФорма.ТипОтметок_Погрузка = Перечисления.Saby_РолиКонтрагентовЭтрН.Отправитель; 
	ЭтаФорма.ТипОтметок_Выгрузка = Перечисления.Saby_РолиКонтрагентовЭтрН.Получатель;
	
	// Телефоны  
	ПоискОсновногоНомераТелефона(Перечисления.Saby_РолиКонтрагентовЭтрН.Отправитель);
	ПоискОсновногоНомераТелефона(Перечисления.Saby_РолиКонтрагентовЭтрН.Получатель);
	ПоискОсновногоНомераТелефона(Перечисления.Saby_РолиКонтрагентовЭтрН.Перевозчик);
	ПоискОсновногоНомераТелефона(Перечисления.Saby_РолиКонтрагентовЭтрН.Отгрузчик);
	ПоискОсновногоНомераТелефона(Перечисления.Saby_РолиКонтрагентовЭтрН.ВладелецОбъекта);
	
	// Даты. Разложим дату и время по отдельным реквизитам 
	РазложитьДатуВремяПоРеквизитам("Отправитель_ДоставитьДо",            "ДоставитьДо_Дата",              "ДоставитьДо_Время");
	РазложитьДатуВремяПоРеквизитам("Погрузка_ДатаВремя",                 "Погрузка_Дата",                 "Погрузка_Время");
	РазложитьДатуВремяПоРеквизитам("Погрузка_ДатаВремяПрибыл",           "Погрузка_ДатаПрибыл",           "Погрузка_ВремяПрибыл");
	РазложитьДатуВремяПоРеквизитам("Погрузка_ДатаВремяУбыл",             "Погрузка_ДатаУбыл",             "Погрузка_ВремяУбыл");
	РазложитьДатуВремяПоРеквизитам("Перевозчик_ПриемкаДатаВремя",        "Перевозчик_ПриемкаДата",        "Перевозчик_ПриемкаВремя");
	РазложитьДатуВремяПоРеквизитам("Перевозчик_ПриемкаДатаВремяПрибыл",  "Перевозчик_ПриемкаДатаПрибыл",  "Перевозчик_ПриемкаВремяПрибыл");
	РазложитьДатуВремяПоРеквизитам("Перевозчик_ПриемкаДатаВремяУбыл",    "Перевозчик_ПриемкаДатаУбыл",    "Перевозчик_ПриемкаВремяУбыл");
	РазложитьДатуВремяПоРеквизитам("Выгрузка_ДатаВремя",                 "Выгрузка_Дата",                 "Выгрузка_Время");
	РазложитьДатуВремяПоРеквизитам("Выгрузка_ДатаВремяПрибыл",           "Выгрузка_ДатаПрибыл",           "Выгрузка_ВремяПрибыл");
	РазложитьДатуВремяПоРеквизитам("Выгрузка_ДатаВремяУбыл",             "Выгрузка_ДатаУбыл",             "Выгрузка_ВремяУбыл" );
	РазложитьДатуВремяПоРеквизитам("Перевозчик_ВыгрузкаДатаВремя",       "Перевозчик_ВыгрузкаДата",       "Перевозчик_ВыгрузкаВремя");
	РазложитьДатуВремяПоРеквизитам("Перевозчик_ВыгрузкаДатаВремяПрибыл", "Перевозчик_ВыгрузкаДатаПрибыл", "Перевозчик_ВыгрузкаВремяПрибыл");
	РазложитьДатуВремяПоРеквизитам("Перевозчик_ВыгрузкаДатаВремяУбыл",   "Перевозчик_ВыгрузкаДатаУбыл",   "Перевозчик_ВыгрузкаВремяУбыл");
	
	// Документ основание
	Если ЗначениеЗаполнено(Объект.ДокументОснование_Идентификатор) Тогда 		
		 ЭтаФорма.ДокументОснование = Документы[Объект.ДокументОснование_ОбъектМетаданных].ПолучитьСсылку(Объект.ДокументОснование_Идентификатор);		
	КонецЕсли;
	
	// Ограничение типов документа 
	// по конфигурации 	
	МассивТипов = Новый Массив();
	
	// есть везде на данный момент
	МассивТипов.Добавить(Тип("ДокументСсылка.РеализацияТоваровУслуг"));
	
	Если Метаданные.Синоним = "Бухгалтерия предприятия, редакция 3.0" Тогда 
		
		МассивТипов.Добавить(Тип("ДокументСсылка.ВозвратТоваровПоставщику"));
		МассивТипов.Добавить(Тип("ДокументСсылка.ПутевойЛист"));       
		
	ИначеЕсли Метаданные.Синоним = "Бухгалтерия предприятия, редакция 2.0" Тогда  	
		
		МассивТипов.Добавить(Тип("ДокументСсылка.ВозвратТоваровПоставщику"));
		МассивТипов.Добавить(Тип("ДокументСсылка.ПеремещениеТоваров"));     
		
	Иначе 
		//Метаданные.Синоним = "1С:ERP Управление предприятием 2" Тогда 
		
		//МассивТипов.Добавить(Тип("ДокументСсылка.РеализацияТоваровУслуг"));
		
		//ToDo: 	
		// УТ
		// УПП
		
	КонецЕсли;
	
	Если МассивТипов.Количество() Тогда  
		НашеОписание = Новый ОписаниеТипов(МассивТипов);
		
		Элементы.ДокументОснование.ОграничениеТипа = НашеОписание; 
		//ЭтаФорма.ДокументОснование = НашеОписание.ПривестиЗначение(ЭтаФорма.ДокументОснование); 
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьВидимостьИДоступностьЭлементов()
	
	Неизвестен = Перечисления.Saby_ВладелецОбъектаОтгрузки.Неизвестен;	
	Элементы.Владелец_НеизвестенПричина.Видимость  = (Объект.Владелец_Тип = Неизвестен); 
	
	Элементы.Грузополучатель.Доступность = НЕ Грузоотправитель_Грузополучатель;
	Элементы.Группа_Заказчик.Видимость   = Объект.Отправитель_Экспедитор;
	
	// Грузоотправитель_ОсуществляетОтгрузку
	Элементы.Отгрузчик.Доступность                    = НЕ Грузоотправитель_ОсуществляетОтгрузку;
	Элементы.Отгрузка_НаОснованииДокумент.Доступность = НЕ Грузоотправитель_ОсуществляетОтгрузку;
	Элементы.Группа_ПогрузкаОтветственный.Доступность = НЕ Грузоотправитель_ОсуществляетОтгрузку;
		
	//ЭтаФорма.ОбновитьОтображениеДанных();
	
	// Владелец 
	Если Объект.Владелец_Тип = Перечисления.Saby_ВладелецОбъектаОтгрузки.Отправитель Тогда
		
		Элементы.Группа_Владелец.Видимость            = Ложь;
		Элементы.Владелец_НеизвестенПричина.Видимость = Ложь;
				
	ИначеЕсли Объект.Владелец_Тип = Перечисления.Saby_ВладелецОбъектаОтгрузки.ДругоеЮрЛицо Тогда 
		
		Элементы.Группа_Владелец.Видимость            = Истина;
		Элементы.Владелец_НеизвестенПричина.Видимость = Ложь;
		
	Иначе
		// Неизвестен
	    Элементы.Группа_Владелец.Видимость            = Ложь;
		Элементы.Владелец_НеизвестенПричина.Видимость = Истина;
		
	КонецЕсли;	
    // - 		

	Элементы.ДокументОснование.Видимость = (Объект.ТипЭтрН = Перечисления.Saby_ТипЭтрНВЛокальнойБазе.Исходящий); 
	
	// Отказ
	Элементы.ГруппаОтказ.Видимость = Объект.Приемка_Отказ;
	
КонецПроцедуры	

&НаСервереБезКонтекста
Функция ДанныеОбъекта(Ссылка, СписокРеквизитов, КонтактнаяИнформация = Ложь)
	
	РеквизитыОбъекта = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Ссылка, СписокРеквизитов);
	
	РазобратьФИО = Ложь;
	Если Метаданные.Синоним = "Управление производственным предприятием, редакция 1.3" Тогда 
		
	   РазобратьФИО = (РеквизитыОбъекта.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо);
	
	Иначе 
		
		Если РеквизитыОбъекта.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо
			Или РеквизитыОбъекта.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ИндивидуальныйПредприниматель Тогда
			
			РазобратьФИО = Истина;
						
		КонецЕсли;	
		
	КонецЕсли;	
		
	Если РазобратьФИО Тогда
		
		МассивФИО = СтрРазделить(РеквизитыОбъекта.Наименование, " ");
		
		СтруктураФИО = Новый Структура;
		СтруктураФИО.Вставить("Фамилия",  ДанныеЭлементаМассива(МассивФИО, 0));
		СтруктураФИО.Вставить("Имя",      ДанныеЭлементаМассива(МассивФИО, 1));
		СтруктураФИО.Вставить("Отчество", ДанныеЭлементаМассива(МассивФИО, 2));
		
		ФИОСтрокой = ЗначениеВСтрокуВнутр(СтруктураФИО);
		
		РеквизитыОбъекта.Вставить("СтруктураФИО", ФИОСтрокой);         
		
	КонецЕсли;
		
	Если КонтактнаяИнформация Тогда
		
		КонтИнфо = КонтактнаяИнформация(Ссылка);
		РеквизитыОбъекта.Вставить("Адрес",     КонтИнфо.АдресЮр);
		РеквизитыОбъекта.Вставить("АдресФакт", КонтИнфо.АдресФакт);
		
		РеквизитыОбъекта.Вставить("КонтИнфо",  КонтИнфо.КИ);
		
	КонецЕсли;
			
	Возврат РеквизитыОбъекта;

КонецФункции

&НаСервереБезКонтекста
Функция ДанныеЭлементаМассива(Массив, НомерЭлемента)
	
	Попытка 
		Значение = Массив[НомерЭлемента];
	Исключение	
	    Значение = "";
	КонецПопытки;
	
	Возврат Значение;

КонецФункции
	
&НаКлиенте
Процедура ПослеВводаПричиныОтказа(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	
	Если ЗначениеЗаполнено(РезультатЗакрытия) Тогда 
				
		Объект.Приемка_Отказ        = Истина; 
		Объект.Приемка_ОтказПричина = РезультатЗакрытия;
		
		ЭтаФорма.Модифицированность = Истина;
		
		ОбновитьВидимостьИДоступностьЭлементов();
		
	Иначе 
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Для отказа от приеки груза укажите причину";
		Сообщение.Поле  = "ФормаОтказВПриемкеГруза";
		Сообщение.Сообщить();
		
	КонецЕсли;
			
КонецПроцедуры

#КонецОбласти

