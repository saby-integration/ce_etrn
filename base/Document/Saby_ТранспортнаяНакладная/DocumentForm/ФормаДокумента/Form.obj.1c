	   
#Область ОбработчикиСобытийФормы
	   	   
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	//ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	ЗаполнитьРасчетныеРеквизиты();
	ОбновитьВидимостьИДоступностьЭлементов();
	
	// Расчет максимальных ключей строк 
    // для первоначального заполнения данных, по этим ключам идет получение новых при добавлении строк
    МаксимальныеКлючиСтрок();
	
	// Необходимых данных в текущей конфигурапции может не быть, дополним данные конфигурации 
	Saby_ТНОбщегоНазначенияСервер.ЗаполнениеДополнительныхДанных();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ) 
	
	// установим отборы по таблицам для корректного отображения информации	
	УстановитьОтборыПоТаблицам();
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если Не ЗначениеЗаполнено(Объект.ВладелецОбъекта) 
		И Объект.Владелец_Тип = ПредопределенноеЗначение("Перечисление.Saby_ВладелецОбъектаОтгрузки.Отправитель") 
		И ЗначениеЗаполнено(Объект.Отправитель) Тогда
		
		Объект.ВладелецОбъекта = Объект.Отправитель;
		
	КонецЕсли;	
	
	// Даты. Соберем даты и время (дата и время находятся в реквизитах формы раздельно) 
	СобратьДатуВремяПоРеквизитам("Отправитель_ДоставитьДо",            "ДоставитьДо_Дата",              "ДоставитьДо_Время");
	СобратьДатуВремяПоРеквизитам("Погрузка_ДатаВремя",                 "Погрузка_Дата",                 "Погрузка_Время");
	СобратьДатуВремяПоРеквизитам("Погрузка_ДатаВремяПрибыл",           "Погрузка_ДатаПрибыл",           "Погрузка_ВремяПрибыл");
	СобратьДатуВремяПоРеквизитам("Погрузка_ДатаВремяУбыл",             "Погрузка_ДатаУбыл",             "Погрузка_ВремяУбыл");
	СобратьДатуВремяПоРеквизитам("Перевозчик_ПриемкаДатаВремя",        "Перевозчик_ПриемкаДата",        "Перевозчик_ПриемкаВремя");
	СобратьДатуВремяПоРеквизитам("Перевозчик_ПриемкаДатаВремяПрибыл",  "Перевозчик_ПриемкаДатаПрибыл",  "Перевозчик_ПриемкаВремяПрибыл");
	СобратьДатуВремяПоРеквизитам("Перевозчик_ПриемкаДатаВремяУбыл",    "Перевозчик_ПриемкаДатаУбыл",    "Перевозчик_ПриемкаВремяУбыл");
	СобратьДатуВремяПоРеквизитам("Выгрузка_ДатаВремя",                 "Выгрузка_Дата",                 "Выгрузка_Время");
	СобратьДатуВремяПоРеквизитам("Выгрузка_ДатаВремяПрибыл",           "Выгрузка_ДатаПрибыл",           "Выгрузка_ВремяПрибыл");
	СобратьДатуВремяПоРеквизитам("Выгрузка_ДатаВремяУбыл",             "Выгрузка_ДатаУбыл",             "Выгрузка_ВремяУбыл" );
	СобратьДатуВремяПоРеквизитам("Перевозчик_ВыгрузкаДатаВремя",       "Перевозчик_ВыгрузкаДата",       "Перевозчик_ВыгрузкаВремя");
	СобратьДатуВремяПоРеквизитам("Перевозчик_ВыгрузкаДатаВремяПрибыл", "Перевозчик_ВыгрузкаДатаПрибыл", "Перевозчик_ВыгрузкаВремяПрибыл");
	СобратьДатуВремяПоРеквизитам("Перевозчик_ВыгрузкаДатаВремяУбыл",   "Перевозчик_ВыгрузкаДатаУбыл",   "Перевозчик_ВыгрузкаВремяУбыл");
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДокументОснованиеПриИзменении(Элемент)
	
	ЭтаФорма.Модифицированность = Истина;
	Если ЗначениеЗаполнено(ДокументОснование) Тогда		
						
        Объект.ДокументОснование_ОбъектМетаданных = ИмяМетаданныхДокумента(ДокументОснование);
		Если ЗначениеЗаполнено(Объект.ДокументОснование_ОбъектМетаданных) Тогда 
			Объект.ДокументОснование_Идентификатор = ДокументОснование.УникальныйИдентификатор();
		Иначе
			Объект.ДокументОснование_Идентификатор = "";
		КонецЕсли;
		
		// ToDo: Вызов Blockly для обсчета ini
		// когда то тут должна быть эта процедура....пока хард код		
		АдресНастроек = НачальноеЗаполнениеДанных();		
		
		СтруктураНастроек = ПолучитьИзВременногоХранилища(АдресНастроек);
		
		// обработка результата...
		Если СтруктураНастроек.НовыйОтправитель Тогда 
			УстановитьУдалитьДанныеЮрЛица(Объект.Отправитель, "Отправитель");
		КонецЕсли;
		
		Если СтруктураНастроек.НовыйПолучатель Тогда
			УстановитьУдалитьДанныеЮрЛица(Объект.Получатель, "Получатель");
		КонецЕсли;
		
		Если СтруктураНастроек.НовыйПеревозчик Тогда
			УстановитьУдалитьДанныеЮрЛица(Объект.Перевозчик, "Перевозчик");
		КонецЕсли;
		
	Иначе 
		
		Объект.ДокументОснование_Идентификатор    = "";
		Объект.ДокументОснование_ОбъектМетаданных = "";
		
	КонецЕсли;
		
КонецПроцедуры

&НаСервереБезКонтекста
Функция ИмяМетаданныхДокумента(ДокументОснование)
	
	ТипЗначения = ТипЗнч(ДокументОснование);
	ОбъектМетаданных = Метаданные.НайтиПоТипу(ТипЗначения);
	Если Метаданные.Документы.Содержит(ОбъектМетаданных) Тогда
		 ИмяДокумента = ДокументОснование.Метаданные().Имя; 
	Иначе 
		 ИмяДокумента = "";
	КонецЕсли;
	
	Возврат ИмяДокумента;
	
КонецФункции

#Область ЮрЛица 

&НаКлиенте
Процедура Владелец_ТипПриИзменении(Элемент)
	
	Роль  = "ВладелецОбъекта";
	
	Если СокрЛП(Объект.Владелец_Тип) <> "Неизвестен" Тогда
		Если ЗначениеЗаполнено(Объект.Владелец_НеизвестенПричина) Тогда 
			Объект.Владелец_НеизвестенПричина = "";	                        
		КонецЕсли;	 	
	КонецЕсли;	    
	
	Если Объект.Владелец_Тип = ПредопределенноеЗначение("Перечисление.Saby_ВладелецОбъектаОтгрузки.ДругоеЮрЛицо") Тогда 
		
		Объект.ВладелецОбъекта = ""; 
		
		// заполним новые данные, в том числе КИ
		УстановитьУдалитьДанныеЮрЛица(Объект.ВладелецОбъекта, Роль);
		
	ИначеЕсли СокрЛП(Объект.Владелец_Тип) = "Отправитель" Тогда  
		
		Объект.ВладелецОбъекта = Объект.Отправитель;
		
		// заполним новые данные, в том числе КИ
		УстановитьУдалитьДанныеЮрЛица(Объект.ВладелецОбъекта, Роль);
		
	КонецЕсли;	
	
	ОбновитьВидимостьИДоступностьЭлементов();

КонецПроцедуры

&НаКлиенте
Процедура Грузоотправитель_ГрузополучательПриИзменении(Элемент)
	
	Роль  = "Получатель";
	
	Если Грузоотправитель_Грузополучатель Тогда
		
		Объект.Получатель = Объект.Отправитель;		
		КопироватьКИОтправителя(Роль);
		
		// заполнить основной номер
		ЭтаФорма.Грузополучатель_Телефон = ЭтаФорма.Грузоотправитель_Телефон; 
		
	Иначе 	
		
		Объект.Получатель           = "";
		ЭтаФорма.Грузополучатель_Телефон = "";
						
		ОчиститьКонтактнуюИнформацию(Роль);
		
	КонецЕсли;	

	УстановитьУдалитьДанныеЮрЛица(Объект.Получатель, Роль);
	
	ОбновитьВидимостьИДоступностьЭлементов();
	
КонецПроцедуры

&НаКлиенте
Процедура Грузоотправитель_ОсуществляетОтгрузкуПриИзменении(Элемент)
	
	Роль  = "Отгрузчик";
	
	Если Грузоотправитель_ОсуществляетОтгрузку Тогда 
		
		Объект.Отгрузчик = Объект.Отправитель;				
		КопироватьКИОтправителя(Роль);
		
		// заполнить основной номер
		ЭтаФорма.Отгрузка_Телефон = ЭтаФорма.Грузоотправитель_Телефон; 

	Иначе
		
		Объект.Отгрузчик = "";
		ЭтаФорма.Отгрузка_Телефон   = "";		
								
		ОчиститьКонтактнуюИнформацию(Роль);
		
	КонецЕсли;	
	
	УстановитьУдалитьДанныеЮрЛица(Объект.Отгрузчик, Роль);

	ОбновитьВидимостьИДоступностьЭлементов();  
	
КонецПроцедуры

&НаКлиенте
Процедура ГрузоотправительПриИзменении(Элемент)
	
	Роль  = "Отправитель";
			
	// заполним новые данные, в том числе КИ
	УстановитьУдалитьДанныеЮрЛица(Объект.Отправитель, Роль);
	
	Если Грузоотправитель_ОсуществляетОтгрузку Тогда 
		
		Объект.ВладелецОбъекта = Объект.Отправитель;
		
		Роль  = "ВладелецОбъекта";
		
		// заполним новые данные, в том числе КИ
		УстановитьУдалитьДанныеЮрЛица(Объект.ВладелецОбъекта, Роль);
		
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ГрузополучательПриИзменении(Элемент)
	
	Роль  = "Получатель";
		
	// заполним новые данные, в том числе КИ
	УстановитьУдалитьДанныеЮрЛица(Объект.Получатель, Роль);
	
КонецПроцедуры

&НаКлиенте
Процедура ПеревозчикПриИзменении(Элемент)
	
	Роль  = "Перевозчик";
		
	// заполним новые данные, в том числе КИ
	УстановитьУдалитьДанныеЮрЛица(Объект.Перевозчик, Роль);
	
КонецПроцедуры

&НаКлиенте
Процедура Отгрузка_ОрганизацияПриИзменении(Элемент)
	
	Роль  = "Отгрузчик";
	
	// заполним новые данные, в том числе КИ
	УстановитьУдалитьДанныеЮрЛица(Объект.Отгрузчик, Роль);
	
КонецПроцедуры

&НаКлиенте
Процедура ВладелецПриИзменении(Элемент)
	
	Роль  = "ВладелецОбъекта";
	
	// заполним новые данные, в том числе КИ
	УстановитьУдалитьДанныеЮрЛица(Объект.ВладелецОбъекта, Роль);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаказчикПриИзменении(Элемент)
	
	Роль  = "Заказчик";
		
	// заполним новые данные, в том числе КИ
	УстановитьУдалитьДанныеЮрЛица(Объект.Получатель, Роль);  
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьУдалитьДанныеЮрЛица(ЮрЛицо, Роль)
	
	ЗначениеРоли = ПредопределенноеЗначение("Перечисление.Saby_РолиКонтрагентовЭтрН." + Роль);
	
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("Роль", ЗначениеРоли);
	
	НайденныеСтроки = Объект.ДанныеЮрЛиц.НайтиСтроки(СтруктураПоиска);
	
	// зачистим текущие данные если они есть
	Если НайденныеСтроки.Количество() Тогда		
		Строка = НайденныеСтроки[0];
		Объект.ДанныеЮрЛиц.Удалить(Строка);		
	КонецЕсли;
	
	// удалим КИ что была до изменения
	ОчиститьКонтактнуюИнформацию(Роль);
	
	// если юрлицо заполнено соберем данные по нему
	Если ЗначениеЗаполнено(ЮрЛицо) Тогда
		
		Строка = Объект.ДанныеЮрЛиц.Добавить();
		Строка.Роль = ЗначениеРоли; 
		
		Если ТипЗнч(ЮрЛицо) = Тип("СправочникСсылка.Организации") Тогда  
			
			РеквизитыСтрокой = "ИНН, КПП, ОГРН, ЮрФизЛицо, СтранаРегистрации, Наименование";
			// контактная информация заполняется отдельно, по последнему параметру
			РеквизитыОбъекта = ДанныеОбъекта(ЮрЛицо, РеквизитыСтрокой, Истина);	
			
		Иначе
			
			РеквизитыСтрокой = "ИНН, КПП, РегистрационныйНомер, ЮрФизЛицо, СтранаРегистрации, Наименование";	
			
			// контактная информация заполняется отдельно, по последнему параметру
			РеквизитыОбъекта = ДанныеОбъекта(ЮрЛицо, РеквизитыСтрокой, Истина);
			Строка.ОГРН = РеквизитыОбъекта.РегистрационныйНомер;  
			
		КонецЕсли;
				
		ЗаполнитьЗначенияСвойств(Строка, РеквизитыОбъекта);		
		
		// Адрес
		Если ЗначениеЗаполнено(РеквизитыОбъекта.Адрес) Тогда 
			Строка.Адрес          = РеквизитыОбъекта.Адрес.Значение;
			Строка.АдресСтруктура = РеквизитыОбъекта.Адрес.Структура;
		КонецЕсли;
				
		// Телефоны и емейл
		Для Каждого Данные Из РеквизитыОбъекта.КонтИнфо Цикл
			
             НС = Объект.КонтактныеДанные.Добавить();
			 НС.Роль = ЗначениеРоли;
			 ЗаполнитьЗначенияСвойств(НС, Данные);
			 
		КонецЦикла;
		
		// Адреса доставки и погрузки 
		Если Роль = "Отправитель" 
			И ЗначениеЗаполнено(РеквизитыОбъекта.АдресФакт) Тогда 
			
			Объект.Погрузка_Адрес = РеквизитыОбъекта.АдресФакт.Значение;         
		КонецЕсли;
					
		Если Роль = "Получатель" 
			И ЗначениеЗаполнено(РеквизитыОбъекта.АдресФакт) Тогда 
			
			Объект.Отправитель_АдресДоставки = РеквизитыОбъекта.АдресФакт.Значение; 
					
		КонецЕсли;
				
	КонецЕсли;
	
	// установка нового номера на форме
	ПоискОсновногоНомераТелефона(ЗначениеРоли);
	
КонецПроцедуры

&НаКлиенте
Процедура Грузоотправитель_ЭкспедиторПриИзменении(Элемент)
	
	Если НЕ Объект.Отправитель_Экспедитор Тогда 
		Объект.Заказчик         = "";
		Объект.Заказчик_Договор = "";
	КонецЕсли;
	
	ОбновитьВидимостьИДоступностьЭлементов(); 
	
КонецПроцедуры

#КонецОбласти

#Область РаботаСКонтактнойИнформацией

// Поиск в контактных данных основного номера телефона
// 
// Параметры:
// Роль - значение роли контрагента (Перечисление)
// ИзменитьНомер - признак меняем номер или нет (Булево)
//
&НаСервере 
Процедура ПоискОсновногоНомераТелефона(Роль, ИзменитьНомер = Ложь)
	
	// обработка телефона определенной роли контрагента
	Если ТипЗнч(Роль) = Тип("Строка") Тогда
		Роль = Перечисления.Saby_РолиКонтрагентовЭтрН[Роль];
	КонецЕсли;
		
	Отбор = Новый Структура;
	Отбор.Вставить("Тип",  Перечисления.ТипыКонтактнойИнформации.Телефон);
	Отбор.Вставить("Роль", Роль);
	
	СоответствиеПолей = СоответствиеРолейИПолейОсновногоТелефона();			
		
	// не всегда нужен основной телефон на форме
	НазваниеПоля = СоответствиеПолей.Получить(Роль);
	Если НазваниеПоля = Неопределено Тогда 
		Возврат;
	КонецЕсли;
		
	НайденныеСтроки = Объект.КонтактныеДанные.НайтиСтроки(Отбор);
	Если НайденныеСтроки.Количество() Тогда 
		
		Если ИзменитьНомер Тогда          
			
			Если ЗначениеЗаполнено(ЭтаФорма[НазваниеПоля]) Тогда 
				
				НайденныеСтроки[0].Значение = ЭтаФорма[НазваниеПоля];
				ЭтаФорма.Модифицированность = Истина;
				
			КонецЕсли;
			
		Иначе 					
			ЭтаФорма[НазваниеПоля] = НайденныеСтроки[0].Значение;
		КонецЕсли;
			 	
	Иначе
		
		// строка не найдена, добавим новую
		Если ИзменитьНомер 
			И ЗначениеЗаполнено(ЭтаФорма[НазваниеПоля]) Тогда
			
			// Новый номер
			НС = Объект.КонтактныеДанные.Добавить();
			НС.Роль     = Роль;
			НС.Тип      = Перечисления.ТипыКонтактнойИнформации.Телефон;
			НС.Значение = ЭтаФорма[НазваниеПоля];
			
			ЭтаФорма.Модифицированность = Истина;
			
		Иначе 	
			
			// сбросим значение
		    ЭтаФорма[НазваниеПоля] = "";	
			
		КонецЕсли;		
		
	КонецЕсли;		
				
КонецПроцедуры

&НаСервере 
Процедура КопироватьКИОтправителя(РольСтрокой)
	
    Роль = Перечисления.Saby_РолиКонтрагентовЭтрН[РольСтрокой];
	
	РольОтправитель = Перечисления.Saby_РолиКонтрагентовЭтрН.Отправитель;
		
	// обработка телефона определенной роли контрагента
			
	Отбор = Новый Структура;
	Отбор.Вставить("Роль", Роль);
					
	// удалим КИ, если она есть
	НайденныеСтроки = Объект.КонтактныеДанные.НайтиСтроки(Отбор);
    Для Каждого Строка Из НайденныеСтроки Цикл  		
		Объект.КонтактныеДанные.Удалить(Строка);						
	КонецЦикла;                
	
	// добавим новую КИ отправителя	
	Отбор = Новый Структура;
	Отбор.Вставить("Роль", РольОтправитель);
		
	// удалим КИ, если она есть
	НайденныеСтроки = Объект.КонтактныеДанные.НайтиСтроки(Отбор);
	Для Каждого Строка Из НайденныеСтроки Цикл 
	
		// Новый номер
		НС = Объект.КонтактныеДанные.Добавить();
		ЗаполнитьЗначенияСвойств(НС, Строка);
		НС.Роль = Роль;
											
	КонецЦикла;		
	
	ЭтаФорма.Модифицированность = Истина;
	
КонецПроцедуры

// Возвращает соответствие ролей контрагентов и полей телефона,
// в которые выводится основной номер телефона
//
// Возвращаемое значение:
//    Соответствие - 
//    Ключ - Значение роли(перечисление)
//    Значение - имя поля на форме(Строка)
&НаСервереБезКонтекста
Функция СоответствиеРолейИПолейОсновногоТелефона()
	
	Соответствие = Новый Соответствие;
	Соответствие.Вставить(Перечисления.Saby_РолиКонтрагентовЭтрН.Отправитель,     "Грузоотправитель_Телефон");
	Соответствие.Вставить(Перечисления.Saby_РолиКонтрагентовЭтрН.Получатель,      "Грузополучатель_Телефон");
	Соответствие.Вставить(Перечисления.Saby_РолиКонтрагентовЭтрН.Перевозчик,      "Перевозчик_Телефон");
	Соответствие.Вставить(Перечисления.Saby_РолиКонтрагентовЭтрН.Отгрузчик,       "Отгрузка_Телефон");
	Соответствие.Вставить(Перечисления.Saby_РолиКонтрагентовЭтрН.ВладелецОбъекта, "Владелец_Телефон");
		
	Возврат Соответствие;
	
КонецФункции

&НаКлиенте
Процедура ОтборИнформацииПоКонтактнымДанным(ИмяТЧ, Значение)
	
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("Роль", ПредопределенноеЗначение("Перечисление.Saby_РолиКонтрагентовЭтрН." + Значение));
	Элементы[ИмяТЧ].ОтборСтрок = Новый ФиксированнаяСтруктура(СтруктураПоиска);
					
КонецПроцедуры  

