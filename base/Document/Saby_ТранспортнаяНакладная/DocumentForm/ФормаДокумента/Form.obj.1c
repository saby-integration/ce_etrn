&НаСервереБезКонтекста
Функция КонтактнаяИнформация(Ссылка)
	
	МассивКИ = Новый Массив;
	
	СтруктураКИ = Новый Структура;
	СтруктураКИ.Вставить("АдресЮр",   "");
	СтруктураКИ.Вставить("АдресФакт", "");
	СтруктураКИ.Вставить("КИ", МассивКИ);
		
	ВидыКИ = Saby_ТНОбщегоНазначенияСервер.ВидыКонтактнойИнформации(Ссылка);	
		
	// Юр.Адрес		
	СтруктураКИ.АдресЮр = 
	Saby_ТНОбщегоНазначенияСервер.КонтактнаяИнформацияОбъекта(
	Ссылка, 
	Справочники.ВидыКонтактнойИнформации[ВидыКИ.АдресЮр]);
	
	// Факт Адрес 	
	СтруктураКИ.АдресФакт = 
	Saby_ТНОбщегоНазначенияСервер.КонтактнаяИнформацияОбъекта(
	Ссылка, 
	Справочники.ВидыКонтактнойИнформации[ВидыКИ.АдресФакт]);
	
	// Телефоны
	Телефоны = 
	Saby_ТНОбщегоНазначенияСервер.КонтактнаяИнформацияОбъекта(
	Ссылка, 
	Справочники.ВидыКонтактнойИнформации[ВидыКИ.Телефон]);
	
	ТипТелефон = Перечисления.ТипыКонтактнойИнформации.Телефон; 
	ДополнитьМассивКИ(Телефоны, ТипТелефон, МассивКИ);
	
	// Емейлы	
	Емейлы = 
	Saby_ТНОбщегоНазначенияСервер.КонтактнаяИнформацияОбъекта(
	Ссылка, 
	Справочники.ВидыКонтактнойИнформации[ВидыКИ.Емайл]);
	
	ТипЕмейл = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
	ДополнитьМассивКИ(Емейлы, ТипЕмейл, МассивКИ);
	
    Возврат СтруктураКИ;

КонецФункции

&НаСервереБезКонтекста
Процедура ДополнитьМассивКИ(Таблица, ТипКИ, МассивКИ)
	
	Если Не Таблица.Количество() Тогда 
		Возврат;
	КонецЕсли;
		
	Для Каждого Строка Из Таблица Цикл
		
		Структура = Новый Структура;
		Структура.Вставить("Значение", Строка.Представление);
		Структура.Вставить("Тип", ТипКИ);
		
		МассивКИ.Добавить(Структура);
		
	КонецЦикла;
		
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область ОбработчикиСобытийЭлементовДополнительныхСтраниц

#Область Грузы

