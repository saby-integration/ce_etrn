#Область ОбработчикиКомандФормы

&НаСервере
Процедура ТестВJSONНаСервере()
	Saby_ТНОбщегоНазначенияСервер.ДанныеДокумента(Объект.Ссылка);
КонецПроцедуры

&НаКлиенте
Процедура ТестВJSON(Команда)
	ТестВJSONНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ОтказВПриемкеГруза(Команда)
	
	Если Объект.Приемка_Отказ Тогда 
		Возврат;		
	КонецЕсли;
	
	Подсказка    = "Укажите причину отказа от приемки груза"; 
	ДопПараметры = Новый Структура;  	
	Оповещение   = Новый ОписаниеОповещения("ПослеВводаПричиныОтказа", ЭтаФорма, ДопПараметры);
	
	ПоказатьВводСтроки(Оповещение, "", Подсказка, 0, Истина);
					
КонецПроцедуры

