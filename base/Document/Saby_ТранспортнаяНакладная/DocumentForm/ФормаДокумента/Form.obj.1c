Функция СтруктураТСиПрицепа()
	
	СтруктураАвто = Неопределено;
	
	СтруктураАвто = Новый Структура;
	СтруктураАвто.Вставить("ГосНомер",         "");
	СтруктураАвто.Вставить("Марка",            "");
	СтруктураАвто.Вставить("Тип",              "");
	СтруктураАвто.Вставить("Вместимость",      0);
    СтруктураАвто.Вставить("Грузоподъемность", 0);
	
	Возврат СтруктураАвто;
	
КонецФункции

