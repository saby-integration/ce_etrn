КонецФункции

Функция ОбщаяСтруктураАдрес()
		
	СтруктураАдрес = Новый Структура;
		
	СтруктураАдрес.Вставить("Индекс",          "");
	СтруктураАдрес.Вставить("КодСтраны",       "643");
	СтруктураАдрес.Вставить("Район",           "");
	СтруктураАдрес.Вставить("Город",           "");
	СтруктураАдрес.Вставить("НаселенныйПункт", "");
	СтруктураАдрес.Вставить("Улица",           "");
	СтруктураАдрес.Вставить("Дом",             "");
	СтруктураАдрес.Вставить("Корпус",          "");
	СтруктураАдрес.Вставить("Квартира",        "");
	СтруктураАдрес.Вставить("Адрес",           "");
			
	Возврат СтруктураАдрес;
		
КонецФункции

// Переопределяемая процедура под свою конфигурацию
// 
Функция КонтактнаяИнформацияОбъекта(СсылкаИлиОбъект, ВидИлиТипКонтактнойИнформации = Неопределено, Дата = Неопределено, ТолькоПредставление = Ложь) Экспорт
	
	Если Дата = Неопределено Тогда
		Дата = ТекущаяДата();
	КонецЕсли;
	
	Если Метаданные.Синоним = "1С:ERP Управление предприятием 2" Тогда
			
		КонтрактнаяИнформация =  
		УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
			СсылкаИлиОбъект, 
			ВидИлиТипКонтактнойИнформации, 
			Дата, 
			ТолькоПредставление
		);
				
		// Обработка возвращаем одиночное значение
		СтруктураАдреса = Новый Структура;
		СтруктураАдреса.Вставить("Значение",  "");
		СтруктураАдреса.Вставить("Структура", "");
		
		Если НЕ ТолькоПредставление
			И ВидИлиТипКонтактнойИнформации = Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации
			Или ВидИлиТипКонтактнойИнформации = Справочники.ВидыКонтактнойИнформации.ФактАдресОрганизации
			Или ВидИлиТипКонтактнойИнформации = Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента
			Или ВидИлиТипКонтактнойИнформации = Справочники.ВидыКонтактнойИнформации.ФактАдресКонтрагента Тогда
			
			Если КонтрактнаяИнформация.Количество() Тогда
				
				СтрокаКИ = КонтрактнаяИнформация[0];
				СтруктураАдреса.Значение  = СтрокаКИ.Представление;
				СтруктураАдреса.Структура = СтрокаКИ.Значение;
				
			КонецЕсли;
			
			Возврат СтруктураАдреса;
			
		Иначе			
			Возврат КонтрактнаяИнформация;			
		КонецЕсли;
				
	ИначеЕсли Метаданные.Синоним = "Управление производственным предприятием, редакция 1.3" Тогда
		
		 Возврат 
		 КонтактнаяИнформацияОбъектаУПП(
			 СсылкаИлиОбъект, 
			 ВидИлиТипКонтактнойИнформации
		 );
						
	КонецЕсли;
	
КонецФункции

// УПП 1.3
//
Функция КонтактнаяИнформацияОбъектаУПП(СсылкаИлиОбъект, ВидИлиТипКонтактнойИнформации) Экспорт
	
	ТипОбъекта = ТипЗнч(СсылкаИлиОбъект);
	Если НЕ ОбщегоНазначения.ЭтоСсылка(ТипОбъекта) Тогда
		Ссылка = СсылкаИлиОбъект.Ссылка;
	Иначе 
		Ссылка = СсылкаИлиОбъект;
	КонецЕсли;	
	
	ТипКИ = Неопределено;
	ВидКИ = Неопределено;
	Если ТипЗнч(ВидИлиТипКонтактнойИнформации) = Тип("ПеречислениеСсылка.ТипыКонтактнойИнформации") Тогда
		ТипКИ = ВидИлиТипКонтактнойИнформации;
	ИначеЕсли ТипЗнч(ВидИлиТипКонтактнойИнформации) = Тип("СправочникСсылка.ВидыКонтактнойИнформации") Тогда
		ВидКИ = ВидИлиТипКонтактнойИнформации;
	КонецЕсли;	
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Объект", Ссылка);
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КонтактнаяИнформация.Объект,
	|	КонтактнаяИнформация.Тип,
	|	КонтактнаяИнформация.Вид,
	|	КонтактнаяИнформация.Представление КАК Представление,
	|	КонтактнаяИнформация.Значение КАК Значение
	|ИЗ
	|	РегистрСведений.КонтактнаяИнформация КАК КонтактнаяИнформация
	|ГДЕ
	|	КонтактнаяИнформация.Объект = &Объект
	|	И 1 = 1";
	
	ТекстЗамены = "";	
	Если ЗначениеЗаполнено(ТипКИ) Тогда 
		
		ТекстЗамены = "КонтактнаяИнформация.Тип = &ТипКИ"; 
		Запрос.УстановитьПараметр("ТипКИ", ТипКИ); 
		
	ИначеЕсли ЗначениеЗаполнено(ВидКИ) Тогда                   
		
	    ТекстЗамены = "КонтактнаяИнформация.Вид = &ВидКИ"; 		
		Запрос.УстановитьПараметр("ВидКИ", ВидКИ);
	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекстЗамены) Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "1 = 1", ТекстЗамены);
	КонецЕсли;
	
	Результат = Запрос.Выполнить().Выгрузить();

	// Обработка возвращаем одиночное значение
	СтруктураАдреса = Новый Структура;
	СтруктураАдреса.Вставить("Значение",  "");
	СтруктураАдреса.Вставить("Структура", "");
	
	Если ВидИлиТипКонтактнойИнформации = Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации
		Или ВидИлиТипКонтактнойИнформации = Справочники.ВидыКонтактнойИнформации.ФактАдресОрганизации
		Или ВидИлиТипКонтактнойИнформации = Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента
		Или ВидИлиТипКонтактнойИнформации = Справочники.ВидыКонтактнойИнформации.ФактАдресКонтрагента Тогда
		
		Если Результат.Количество() Тогда
			
			СтрокаКИ = Результат[0];
			СтруктураАдреса.Значение  = СтрокаКИ.Представление;
			СтруктураАдреса.Структура = СтрокаКИ.Значение;
			
		КонецЕсли;
		
		Возврат СтруктураАдреса;

	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ВидыКонтактнойИнформации(Ссылка) Экспорт 
		
	Если Метаданные.Синоним <> "1С:ERP Управление предприятием 2"	
	И Метаданные.Синоним <> "Управление производственным предприятием, редакция 1.3" Тогда	
		ВызватьИсключение НСтр("ru = 'Данная конфигурация отсутствует в общем модуле! Для формирования контактной информации неободимо сделать сопоставление'");		
	КонецЕсли;
	
	Если ТипЗнч(Ссылка) = Тип("СправочникСсылка.Организации") Тогда  
		
		ВидКИАдресЮр   = "ЮрАдресОрганизации";
		ВидТелефон     = "ТелефонОрганизации";
		ВидЕмайл       = "EmailОрганизации";
		ВидКИАдресФакт = "ФактАдресОрганизации";
		
	Иначе
		
		ВидКИАдресЮр   = "ЮрАдресКонтрагента";
		ВидТелефон     = "ТелефонКонтрагента";		
		ВидКИАдресФакт = "ФактАдресКонтрагента";
		
		Если Метаданные.Синоним = "Управление производственным предприятием, редакция 1.3" Тогда  
			ВидЕмайл = "АдресЭлектроннойПочтыКонтрагентаДляОбменаДокументами";
		Иначе 
            ВидЕмайл = "EmailКонтрагента";
		КонецЕсли;
					
	КонецЕсли;
	
	СтруктураКИ = Новый Структура;
	СтруктураКИ.Вставить("АдресЮр",   ВидКИАдресЮр); 
	СтруктураКИ.Вставить("Телефон",   ВидТелефон);
	СтруктураКИ.Вставить("Емайл",     ВидЕмайл);	
	СтруктураКИ.Вставить("АдресФакт", ВидКИАдресФакт);
	
	Возврат СтруктураКИ;
	
КонецФункции

Процедура ЗаполнениеДополнительныхДанных() Экспорт 
	
	Если Метаданные.Синоним = "Управление производственным предприятием, редакция 1.3" Тогда		
		ВидыХарактеристик = ПроверитьСоздатьДополнительныеРеквизитыУПП();		
	КонецЕсли;
	
КонецПроцедуры

Функция ПроверитьСоздатьДополнительныеРеквизитыУПП() Экспорт
		
	НомерВУ = ПланыВидовХарактеристик.СвойстваОбъектов.НайтиПоНаименованию("СБИС_НомерВУ");
	Если Не ЗначениеЗаполнено(НомерВУ) Тогда
		
		НовыйВид = ПланыВидовХарактеристик.СвойстваОбъектов.СоздатьЭлемент();
		НовыйВид.Наименование = "СБИС_НомерВУ";
		НовыйВид.ТипЗначения = Новый ОписаниеТипов("Строка",,,, Новый КвалификаторыСтроки(20));
		НовыйВид.НазначениеСвойства = ПланыВидовХарактеристик.НазначенияСвойствКатегорийОбъектов.Справочник_ФизическиеЛица;
		
		НовыйВид.УстановитьНовыйКод();		
		НовыйВид.ОбменДанными.Загрузка = Истина;
		НовыйВид.Записать();
		
		НомерВУ = НовыйВид.Ссылка;
		
	КонецЕсли;
		
	СерияВУ = ПланыВидовХарактеристик.СвойстваОбъектов.НайтиПоНаименованию("СБИС_СерияВУ");
	Если Не ЗначениеЗаполнено(СерияВУ) Тогда
		
		НовыйВид = ПланыВидовХарактеристик.СвойстваОбъектов.СоздатьЭлемент();
		НовыйВид.Наименование = "СБИС_СерияВУ";
		НовыйВид.ТипЗначения = Новый ОписаниеТипов("Строка",,,, Новый КвалификаторыСтроки(20));
		НовыйВид.НазначениеСвойства = ПланыВидовХарактеристик.НазначенияСвойствКатегорийОбъектов.Справочник_ФизическиеЛица;
		
		НовыйВид.УстановитьНовыйКод();		
		НовыйВид.ОбменДанными.Загрузка = Истина;
		НовыйВид.Записать();
		
		СерияВУ = НовыйВид.Ссылка;
		
	КонецЕсли;

    ДатаВыдачиВУ = ПланыВидовХарактеристик.СвойстваОбъектов.НайтиПоНаименованию("СБИС_ДатаВыдачиВУ");
	Если Не ЗначениеЗаполнено(ДатаВыдачиВУ) Тогда
		
		НовыйВид = ПланыВидовХарактеристик.СвойстваОбъектов.СоздатьЭлемент();
		НовыйВид.Наименование = "СБИС_НомерВУ";
		НовыйВид.ТипЗначения = Новый ОписаниеТипов("Дата",,,,, Новый КвалификаторыДаты(ЧастиДаты.Дата));
		НовыйВид.НазначениеСвойства = ПланыВидовХарактеристик.НазначенияСвойствКатегорийОбъектов.Справочник_ФизическиеЛица;
		
		НовыйВид.УстановитьНовыйКод();		
		НовыйВид.ОбменДанными.Загрузка = Истина;
		НовыйВид.Записать();
		
		ДатаВыдачиВУ = НовыйВид.Ссылка;
		
	КонецЕсли;

	Структура = Новый Структура;
	Структура.Вставить("НомерВУ",      НомерВУ);
	Структура.Вставить("СерияВУ",      СерияВУ);
	Структура.Вставить("ДатаВыдачиВУ", ДатаВыдачиВУ);
	
	Возврат Структура;
	
КонецФункции

#КонецОбласти
