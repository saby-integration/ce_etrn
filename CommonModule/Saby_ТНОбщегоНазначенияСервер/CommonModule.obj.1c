
#Область ПрограммныйИнтерфейс 

#Область РазобратьДокументВJson

Функция СформироватьСтруктуруJSON(Ссылка) Экспорт
		
	РеквизитыОбъекта = ЗначенияРеквизитовДокументаЭтрН(Ссылка); 
		
	// Собираем общую структуру документа	
	ОбщаяСтруктура = Новый Структура;
	ОбщаяСтруктура.Вставить("Номер",       РеквизитыОбъекта.Номер);
    ОбщаяСтруктура.Вставить("Дата",	       РеквизитыОбъекта.Дата);
	ОбщаяСтруктура.Вставить("НомерЗаказа", РеквизитыОбъекта.Отправитель_ЗаявкаНомер);
	ОбщаяСтруктура.Вставить("ДатаЗаказа",  РеквизитыОбъекта.Отправитель_ЗаявкаДата);
	
	// ТЕСТ
	// ToDo: Убрать
	ОбщаяСтруктура.Вставить("ИД_Сбис",     "123");
	
	// Данные по участникам документооборота
	// внести правки
	ОбщаяСтруктура.Вставить("Грузоотправитель", ДанныеЮрЛица("Отправитель", РеквизитыОбъекта));
	ОбщаяСтруктура.Вставить("Заказчик",         ДанныеЮрЛица("Заказчик",    РеквизитыОбъекта));	
	ОбщаяСтруктура.Вставить("Грузополучатель",  ДанныеЮрЛица("Получатель",  РеквизитыОбъекта));
	
	// Перевозчик
	ОбщаяСтруктура.Вставить("Грузоперевозчик",  ДанныеЮрЛица("Перевозчик",  РеквизитыОбъекта));
		
	// Транспорт и все с ним связанное
	ОбщаяСтруктура.Грузоперевозчик.Вставить("Водители",             ДанныеОВодителях(РеквизитыОбъекта.Водители));
	ОбщаяСтруктура.Грузоперевозчик.Вставить("ТранспортноеСредство", ДанныеТС(РеквизитыОбъекта.Отправитель_ТранспортноеСредство)); 
	ОбщаяСтруктура.Грузоперевозчик.Вставить("Прицепы",              ДанныеПрицепов(РеквизитыОбъекта.Прицепы));		
	ОбщаяСтруктура.Грузоперевозчик.Вставить("СпецРазрешения",       СпецРазрешения(РеквизитыОбъекта.СпецРазрешения));
	// - 
	
	ОбщаяСтруктура.Вставить("Документы", СопроводительныеДокументы(РеквизитыОбъекта));	
	ОбщаяСтруктура.Вставить("Груз",      ДанныеГруза(РеквизитыОбъекта));	
	ОбщаяСтруктура.Вставить("Отметки",   ОтметкиДокумента(РеквизитыОбъекта));
	
	// Доставка  
	ОбщаяСтруктура.Вставить("Доставка", ДанныеДоставки(РеквизитыОбъекта));
				
	////////////////////////////////////////////////////////////////////////////
		
	////////////// Отправка груза Отправителем. Титул 1                              
	////////////ОбщаяСтруктура.Вставить("Отправка", ДанныеОтправки(РеквизитыОбъекта));
	////////////
	////////////// Погрузка груза Перевозчиком. Титул 2
	////////////ОбщаяСтруктура.Вставить("Погрузка", ДанныеПогрузки(РеквизитыОбъекта));
	////////////
	////////////// Приемка груза Получателем. Титул 3
	////////////ОбщаяСтруктура.Вставить("Приемка", ДанныеПриемки(РеквизитыОбъекта));	
	////////////
	////////////// Выдача груза Перевозчиком. Титул 4 	
	////////////ОбщаяСтруктура.Вставить("Выдача", ДанныеВыдачи(РеквизитыОбъекта));
	
	//////////////////////////////////////////////////////////////////////////////////////////////

	// Запакуем в JSON 
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, ОбщаяСтруктура);
	ТелоJSON =  ЗаписьJSON.Закрыть();
		
	Возврат ТелоJSON;
	
КонецФункции

Функция ЗначенияРеквизитовДокументаЭтрН(Ссылка)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Saby_ЭтрН.Ссылка КАК Ссылка,
	|	Saby_ЭтрН.Номер КАК Номер,
	|	Saby_ЭтрН.Дата КАК Дата,
	|	Saby_ЭтрН.ВладелецОбъекта КАК ВладелецОбъекта,
	|	Saby_ЭтрН.Владелец_НеизвестенПричина КАК Владелец_НеизвестенПричина,
	|	Saby_ЭтрН.Владелец_Тип КАК Владелец_Тип,
	|	Saby_ЭтрН.Выгрузка_Адрес КАК Выгрузка_Адрес,
	|	Saby_ЭтрН.Выгрузка_ДатаВремя КАК Выгрузка_ДатаВремя,
	|	Saby_ЭтрН.Выгрузка_ДатаВремяПрибыл КАК Выгрузка_ДатаВремяПрибыл,
	|	Saby_ЭтрН.Выгрузка_ДатаВремяУбыл КАК Выгрузка_ДатаВремяУбыл,
	|	Saby_ЭтрН.Выгрузка_КоличествоМест КАК Выгрузка_КоличествоМест,
	|	Saby_ЭтрН.Выгрузка_МассаБрутто КАК Выгрузка_МассаБрутто,
	|	Saby_ЭтрН.Выгрузка_МассаМетодРасчета КАК Выгрузка_МассаМетодРасчета,
	|	Saby_ЭтрН.Выгрузка_Состояние КАК Выгрузка_Состояние,
	|	Saby_ЭтрН.Отправитель КАК Отправитель,
	|	Saby_ЭтрН.Отправитель_АдресДоставки КАК Отправитель_АдресДоставки,
	|	Saby_ЭтрН.Отправитель_ВлажностьДо КАК Отправитель_ВлажностьДо,
	|	Saby_ЭтрН.Отправитель_ВлажностьОт КАК Отправитель_ВлажностьОт,
	|	Saby_ЭтрН.Отправитель_ДоставитьДо КАК Отправитель_ДоставитьДо,
	|	Saby_ЭтрН.Отправитель_ДоставитьСрок КАК Отправитель_ДоставитьСрок,
	|	Saby_ЭтрН.Отправитель_ЗаявкаДата КАК Отправитель_ЗаявкаДата,
	|	Saby_ЭтрН.Отправитель_ЗаявкаНомер КАК Отправитель_ЗаявкаНомер,
	|	Saby_ЭтрН.Отправитель_ИнициаторПереадресации КАК Отправитель_ИнициаторПереадресации,
	|	Saby_ЭтрН.Отправитель_НормыПеревозки КАК Отправитель_НормыПеревозки,
	|	Saby_ЭтрН.Отправитель_ОграничениеСкорости КАК Отправитель_ОграничениеСкорости,
	|	Saby_ЭтрН.Отправитель_ПерегрузкаЗапрешена КАК Отправитель_ПерегрузкаЗапрешена,
	|	Saby_ЭтрН.Отправитель_Пломба КАК Отправитель_Пломба,
	|	Saby_ЭтрН.Отправитель_СопроводительнаяВедомость КАК Отправитель_СопроводительнаяВедомость,
	|	Saby_ЭтрН.Отправитель_ТемператураДо КАК Отправитель_ТемператураДо,
	|	Saby_ЭтрН.Отправитель_ТемператураОт КАК Отправитель_ТемператураОт,
	|	Saby_ЭтрН.Отправитель_ТранспортноеСредство КАК Отправитель_ТранспортноеСредство,
	|	Saby_ЭтрН.Отправитель_Экспедитор КАК Отправитель_Экспедитор,
	|	Saby_ЭтрН.Получатель КАК Получатель,
	|	Saby_ЭтрН.ИД_Сбис КАК ИД_Сбис,
	|	Saby_ЭтрН.Комментарий КАК Комментарий,
	|	Saby_ЭтрН.Отгрузка_НаОснованииДокумент КАК Отгрузка_НаОснованииДокумент,
	|	Saby_ЭтрН.Отгрузчик КАК Отгрузчик,
	|	Saby_ЭтрН.Отгрузка_Ответственный КАК Отгрузка_Ответственный,
	|	Saby_ЭтрН.Отгрузка_ОтветственныйНаОсновании КАК Отгрузка_ОтветственныйНаОсновании,
	|	Saby_ЭтрН.Перевозчик КАК Перевозчик,
	|	Saby_ЭтрН.Перевозчик_ВыгрузкаДатаВремя КАК Перевозчик_ВыгрузкаДатаВремя,
	|	Saby_ЭтрН.Перевозчик_ВыгрузкаДатаВремяПрибыл КАК Перевозчик_ВыгрузкаДатаВремяПрибыл,
	|	Saby_ЭтрН.Перевозчик_ВыгрузкаДатаВремяУбыл КАК Перевозчик_ВыгрузкаДатаВремяУбыл,
	|	Saby_ЭтрН.Перевозчик_ВыгрузкаЗамечанияПоСостояниюГруза КАК Перевозчик_ВыгрузкаЗамечанияПоСостояниюГруза,
	|	Saby_ЭтрН.Перевозчик_ЗамечанияПоПогрузочнымРаботам КАК Перевозчик_ЗамечанияПоПогрузочнымРаботам,
	|	Saby_ЭтрН.Перевозчик_ЗамечанияПоРазгрузочнымРаботам КАК Перевозчик_ЗамечанияПоРазгрузочнымРаботам,
	|	Saby_ЭтрН.Перевозчик_ПогрузкаЗамечанияПоКоличеству КАК Перевозчик_ПогрузкаЗамечанияПоКоличеству,
	|	Saby_ЭтрН.Перевозчик_ПогрузкаЗамечанияПоМассе КАК Перевозчик_ПогрузкаЗамечанияПоМассе,
	|	Saby_ЭтрН.Перевозчик_ПогрузкаЗамечанияПоСостояниюГруза КАК Перевозчик_ПогрузкаЗамечанияПоСостояниюГруза,
	|	Saby_ЭтрН.Перевозчик_ПриемкаДатаВремя КАК Перевозчик_ПриемкаДатаВремя,
	|	Saby_ЭтрН.Перевозчик_ПриемкаДатаВремяПрибыл КАК Перевозчик_ПриемкаДатаВремяПрибыл,
	|	Saby_ЭтрН.Перевозчик_ПриемкаДатаВремяУбыл КАК Перевозчик_ПриемкаДатаВремяУбыл,
	|	Saby_ЭтрН.Погрузка_Адрес КАК Погрузка_Адрес,
	|	Saby_ЭтрН.Погрузка_ДатаВремя КАК Погрузка_ДатаВремя,
	|	Saby_ЭтрН.Погрузка_ДатаВремяПрибыл КАК Погрузка_ДатаВремяПрибыл,
	|	Saby_ЭтрН.Погрузка_ДатаВремяУбыл КАК Погрузка_ДатаВремяУбыл,
	|	Saby_ЭтрН.Погрузка_КоличествоМест КАК Погрузка_КоличествоМест,
	|	Saby_ЭтрН.Погрузка_Масса КАК Погрузка_Масса,
	|	Saby_ЭтрН.Погрузка_МассаМетодРасчета КАК Погрузка_МассаМетодРасчета,
	|	Saby_ЭтрН.Погрузка_Состояние КАК Погрузка_Состояние,
	|	Saby_ЭтрН.Приемка_МассаБрутто КАК Приемка_МассаБрутто,
	|	Saby_ЭтрН.Приемка_МассаНетто КАК Приемка_МассаНетто,
	|	Saby_ЭтрН.Приемка_Объем КАК Приемка_Объем,
	|	Saby_ЭтрН.Приемка_Отказ КАК Приемка_Отказ,
	|	Saby_ЭтрН.Приемка_ОтказПричина КАК Приемка_ОтказПричина,
	|	Saby_ЭтрН.Приемка_КоличествоМест КАК Приемка_КоличествоМест,
	|	Saby_ЭтрН.ТипЭтрН КАК ТипЭтрН,
	|	Saby_ЭтрН.Заказчик КАК Заказчик,
	|	Saby_ЭтрН.Заказчик_Договор КАК Заказчик_Договор,
	|	Saby_ЭтрН.Акты.(
	|		КлючСтроки_Отметки КАК КлючСтроки_Отметки,
	|		Документ КАК Документ
	|	) КАК Акты,
	|	Saby_ЭтрН.Водители.(
	|		Водитель КАК Водитель
	|	) КАК Водители,
	|	Saby_ЭтрН.Грузы.(
	|		Тип КАК Тип,
	|		Наименование КАК Наименование,
	|		Заказчик КАК Заказчик,
	|		Состояние КАК Состояние,
	|		Количество КАК Количество,
	|		МассаБрутто КАК МассаБрутто,
	|		Объем КАК Объем,
	|		СпособУпаковки КАК СпособУпаковки,
	|		ВидТары КАК ВидТары,
	|		ЕСТЬNULL(ВидТары.Код, """") КАК ВидТарыКод,
	|		МассаНетто КАК МассаНетто,
	|		Длина КАК Длина,
	|		Ширина КАК Ширина,
	|		Высота КАК Высота,
	|		КоличествоПаллет КАК КоличествоПаллет,
	|		Стоимость КАК Стоимость,
	|		Валюта КАК Валюта,
	|       ЕСТЬNULL(Валюта.Код, """") КАК ВалютаКод,
	|		Плотность КАК Плотность,
	|		КлючСтроки КАК КлючСтроки
	|	) КАК Грузы,
	|	Saby_ЭтрН.Контейнеры.(
	|		КлючСтроки_Грузы КАК КлючСтроки_Грузы,
	|		Номер КАК Номер,
	|		Количество КАК Количество
	|	) КАК Контейнеры,
	|	Saby_ЭтрН.Маркировки.(
	|		КлючСтроки_Грузы КАК КлючСтроки_Грузы,
	|		Значение КАК Значение
	|	) КАК Маркировки,
	|	Saby_ЭтрН.ОпасныеГрузы.(
	|		КлючСтроки_Грузы КАК КлючСтроки_Грузы,
	|		ОпасныйГруз КАК ОпасныйГруз,
	|       ОпасныйГруз.НомерООН КАК НомерООН, 
	|	    ОпасныйГруз.Наименование КАК Наименование,
	|	    ОпасныйГруз.Класс КАК Класс,	
	|	    ОпасныйГруз.КлассификационныйКод КАК КлассификационныйКод,
	|	    ЕСТЬNULL(ОпасныйГруз.ГруппаУпаковки, """") КАК ГруппаУпаковки, 
	|	    ОпасныйГруз.ЗнакОпасности КАК ЗнакОпасности, 
	|	    ЕСТЬNULL(ОпасныйГруз.ОграничениеПроездаЧерезТуннели, """") КАК ОграничениеТуннели
	|	) КАК ОпасныеГрузы,
	|	Saby_ЭтрН.Отметки.(
	|		Этап КАК Этап,
	|		Роль КАК Роль,
	|		ДатаВремя КАК ДатаВремя,
	|		Описание КАК Описание,
	|		КлючСтроки КАК КлючСтроки
	|	) КАК Отметки,
	|	Saby_ЭтрН.Прицепы.(
	|		Прицеп КАК Прицеп
	|	) КАК Прицепы,
	|	Saby_ЭтрН.СведенияГосСистем.(
	|		КлючСтроки_Грузы КАК КлючСтроки_Грузы,
	|		НаименованиеГосСистемы КАК НаименованиеГосСистемы,
	|		УчетнаяЕдиница КАК УчетнаяЕдиница,
	|		ИнаяИнформация КАК ИнаяИнформация,
	|		Идентификатор КАК Идентификатор
	|	) КАК СведенияГосСистем,
	|	Saby_ЭтрН.СопроводительныеДокументы.(
	|		СопроводительныйДокумент КАК Документ
	|	) КАК СопроводительныеДокументы,
	|	Saby_ЭтрН.СпецРазрешения.(
	|		Номер КАК Номер,
	|		Дата КАК Дата,
	|		Срок КАК Срок,
	|		ИД КАК ИД
	|	) КАК СпецРазрешения,
	|	Saby_ЭтрН.Штрафы.(
	|		КлючСтроки_Отметки КАК КлючСтроки_Отметки,
	|		Сумма КАК Сумма,
	|		СуммаВВалюте КАК СуммаВВалюте,
	|		Валюта КАК Валюта,
	|		Курс КАК Курс,
	|		ФактическоеКоличество КАК ФактическоеКоличество,
	|		Расчет КАК Расчет
	|	) КАК Штрафы,
	|	Saby_ЭтрН.ИнформационныеПоля.(
	|		Этап КАК Титул,
	|		ИД КАК ИД,
	|		Значение КАК Значение
	|	) КАК ИнформационныеПоля,
	|	Saby_ЭтрН.КонтактныеДанные.(
	|		Роль КАК Роль,
	|		Тип КАК Тип,
	|		Значение КАК Значение
	|	) КАК КонтактныеДанные,
	|	Saby_ЭтрН.ДанныеЮрЛиц.(
	|		Роль КАК Роль,
	|		ИНН КАК ИНН,
	|		КПП КАК КПП,
	|		ОГРН КАК ОГРН,
	|		Адрес КАК Адрес,
	|		ЮрФизЛицо КАК ЮрФизЛицо
	|	) КАК ДанныеЮрЛиц,
	|	Saby_ЭтрН.Представление КАК Представление
	|ИЗ
	|	Документ.Saby_ТранспортнаяНакладная КАК Saby_ЭтрН";
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат[0];
		
КонецФункции
	
#Область ЮрЛица

Функция ДанныеЮрЛица(РольСтрокой, РеквизитыОбъекта)
	
    СтруктураДанных = СтруктураОбщаяЮрЛица();
	
	// если пустое значение вернем пустую структуру
	Если Не ЗначениеЗаполнено(РеквизитыОбъекта[РольСтрокой]) Тогда 
		Возврат СтруктураДанных;
	КонецЕсли;		
		
	Роль = Перечисления.Saby_РолиКонтрагентовЭтрН[РольСтрокой];
	Если Роль = "Отправитель" Тогда
		// не входит в общую структуру
		СтруктураДанных.Вставить("Экспедитор", РеквизитыОбъекта.Отправитель_Экспедитор);
	КонецЕсли;
	
	СтруктураДанных.Название.Полное = СокрЛП(РеквизитыОбъекта[РольСтрокой]);	
		
	// Данные из документа
	Отбор = Новый Структура;
	Отбор.Вставить("Роль", Роль);
	
	НайденныеСтроки = РеквизитыОбъекта.ДанныеЮрЛиц.НайтиСтроки(Отбор);
	Если НайденныеСтроки.Количество() Тогда 		
		СтрокаДанные = НайденныеСтроки[0];
		ОсновныеДанныеЮрЛицаИзДокумента(СтрокаДанные, СтруктураДанных);		
	КонецЕсли;
	 			
	// Телефоны
	Отбор.Вставить("Тип",  Перечисления.ТипыКонтактнойИнформации.Телефон);
	
	НайденныеСтроки = РеквизитыОбъекта.КонтактныеДанные.НайтиСтроки(Отбор);
	Для Каждого Строка Из НайденныеСтроки Цикл 
		СтруктураДанных.Контакты.Телефон.Добавить(Строка.Значение);
	КонецЦикла;	
	
	// Емейлы
	Отбор.Вставить("Тип",  Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты);
	
	НайденныеСтроки = РеквизитыОбъекта.КонтактныеДанные.НайтиСтроки(Отбор);
	Для Каждого Строка Из НайденныеСтроки Цикл 
		СтруктураДанных.Контакты.ЭлектроннаяПочта.Добавить(Строка.Значение);
	КонецЦикла;
		
	Возврат СтруктураДанных;

КонецФункции

Функция СтруктураОбщаяЮрЛица()
		
	// Название
	СтруктураНазвание = Новый Структура;
	СтруктураНазвание.Вставить("Полное", "");	
		
	// Реквизиты
	СтруктураРеквизиты = Новый Структура;	
	СтруктураРеквизиты.Вставить("ИНН",             "");
	СтруктураРеквизиты.Вставить("Информация",      "");
	СтруктураРеквизиты.Вставить("ИП",              СтруктураЮрЛицаИП());
	СтруктураРеквизиты.Вставить("ЮЛ",              СтруктураЮЛ());
	СтруктураРеквизиты.Вставить("ИностранноеЛицо", СтруктураИностранногоЛица());
	СтруктураРеквизиты.Вставить("ФЛ",              СтруктураФизЛицо());
	
	// Контакты	
	СтруктураКонтакты = Новый Структура;
	СтруктураКонтакты.Вставить("Другой",           "");	
	СтруктураКонтакты.Вставить("Телефон",          Новый Массив);
	СтруктураКонтакты.Вставить("ЭлектроннаяПочта", Новый Массив);
		
	// Общая структура
	Структура = Новый Структура;           	
	//Структура.Вставить("Идентификатор", "");
	Структура.Вставить("Название",      СтруктураНазвание);	  		
	Структура.Вставить("Реквизиты",     СтруктураРеквизиты);
	Структура.Вставить("Адрес",         СтруктураЮрЛицаАдрес());
    Структура.Вставить("Контакты",      СтруктураКонтакты);
	
	Возврат Структура;
	
КонецФункции

