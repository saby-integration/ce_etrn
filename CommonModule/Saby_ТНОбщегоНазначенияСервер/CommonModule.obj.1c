Процедура ОсновныеДанныеЮрЛицаИзДокумента(СтрокаДанные, СтруктураДанных)
	
	СтруктураДанных.Реквизиты.ИНН = СтрокаДанные.ИНН; 
	
	Если СтрокаДанные.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицоНеРезидент Тогда
		
		// Не резидент
		// *- не полный
		ИнЛицо = СтруктураДанных.Реквизиты.ИностранноеЛицо; 
		ИнЛицо.Наименование = СтруктураДанных.Название.Полное;
		ИнЛицо.Страна       = СтрокаДанные.Страна;		
			
	ИначеЕсли СтрокаДанные.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ИндивидуальныйПредприниматель Тогда 
		
		// ИП
		ИП = СтруктураДанных.Реквизиты.ИП;				
		ИП.ИНН = СтрокаДанные.ИНН; 
		
		Если ЗначениеЗаполнено(СтрокаДанные.СтруктураФИО) Тогда 		
			СтруктураФИО = ЗначениеИзСтрокиВнутр(СтрокаДанные.СтруктураФИО);
			ЗаполнитьЗначенияСвойств(ИП, СтруктураФИО);			
		КонецЕсли;
					
	ИначеЕсли СтрокаДанные.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо Тогда 
		
		// ФЛ
		ФЛ = СтруктураДанных.Реквизиты.ФЛ;
		ФЛ.ИНН = СтрокаДанные.ИНН;
		
		Если ЗначениеЗаполнено(СтрокаДанные.СтруктураФИО) Тогда 		
			СтруктураФИО = ЗначениеИзСтрокиВнутр(СтрокаДанные.СтруктураФИО);
			ЗаполнитьЗначенияСвойств(ФЛ, СтруктураФИО);			
		КонецЕсли;
		
	Иначе 
		
		// ЮрЛицо		
		ЮЛ = СтруктураДанных.Реквизиты.ЮЛ;				
		ЮЛ.Наименование = СтруктураДанных.Название.Полное; 
		ЮЛ.ИНН          = СтрокаДанные.ИНН;
		ЮЛ.КПП          = СтрокаДанные.КПП;
		
	КонецЕсли;		
	
	// *- адрес не полный
	СтруктураДанных.Адрес.Юридический.Адрес = СтрокаДанные.Адрес;  
	
КонецПроцедуры

Функция СтруктураАдресаОтправкиДоставки()
	
	Структура = ОбщаяСтруктураАдрес();
	
	Структура.Вставить("GLN",         "");
	Структура.Вставить("Код",         "");
	Структура.Вставить("Комментарий", "");
	Структура.Вставить("Широта",      "");
	Структура.Вставить("Долгота",     "");
		
	Возврат Структура;
	
КонецФункции

#КонецОбласти 

#Область Груз

Функция ДанныеГруза(РеквизитыОбъекта)
			
	ДанныеГруза = Новый Массив;
		
	Для Каждого Строка Из РеквизитыОбъекта.Грузы Цикл 
		
		ПараметрыСтроки = СтруктураПозицииГруза();		
		ЗаполнитьЗначенияСвойств(ПараметрыСтроки, Строка);
				
		// обработаем данные строки и перейдем к связанным данным		
		СвязанныеДанные = СвязанныеДанныеСГрузом(РеквизитыОбъекта, Строка.КлючСтроки);
		
		СтруктураКонтейнеры = Новый Структура;
		СтруктураКонтейнеры.Вставить("Количество", СвязанныеДанные.Контейнеры.Количество());
		СтруктураКонтейнеры.Вставить("Контейнер",  СвязанныеДанные.Контейнеры);
		
		ПараметрыСтроки.Вставить("Контейнеры",  СтруктураКонтейнеры);		
		ПараметрыСтроки.Вставить("Маркировка",  СвязанныеДанные.Маркировки);
		ПараметрыСтроки.Вставить("ОпасныйГруз", СвязанныеДанные.ОпасныеГрузы);  		
		ПараметрыСтроки.Вставить("СведенияГИС", СвязанныеДанные.СведенияГосСистем);
		
		ДанныеГруза.Добавить(ПараметрыСтроки);
		
		// Дозаполним данные	
		ПараметрыСтроки.Заказчик           = "";
		ПараметрыСтроки.Тара               = Строка.ВидТарыКод;
		ПараметрыСтроки.Упаковка           = Строка.СпособУпаковки;
		ПараметрыСтроки.СтоимостьСНалогом  = Строка.Стоимость; 
		ПараметрыСтроки.КодВалюты          = "643";
	    ПараметрыСтроки.НаименованиеВалюты = "Российский рубль"; 
		
		Если СвязанныеДанные.СведенияГосСистем.Количество() Тогда 
			ПараметрыСтроки.УчетГИС = Истина;			
		КонецЕсли;
							
	КонецЦикла;
	
	СтруктураГруза = Новый Структура; 
	
	СтруктураСтоимости = Новый Структура;
	СтруктураСтоимости.Вставить("Всего", РеквизитыОбъекта.Грузы.Итог("Стоимость"));
	// рубль по умолчанию. RUB - символьный код. добавить валюту. реквизит документа. Наименование - символьный код
	СтруктураСтоимости.Вставить("КодВалюты",          "643");
	СтруктураСтоимости.Вставить("НаименованиеВалюты", "Российский рубль"); 
	
	СтруктураГруза.Вставить("Стоимость", СтруктураСтоимости);	
	СтруктураГруза.Вставить("Позиция",   ДанныеГруза);
			
	////////СопроводитДокументы = СопроводительныеДокументы(РеквизитыОбъекта);
	///////СтруктураГруза.Вставить("СопроводДокументы", СопроводитДокументы);
	
	Возврат СтруктураГруза;
	
КонецФункции

// Поиск и заполнение данных по связанным табличным частям
// Возвращаемое значение: 
// Структура 
Функция СвязанныеДанныеСГрузом(РеквизитыОбъекта, КлючСтроки)
	
	Контейнеры        = Новый Массив;
	Маркировки        = Новый Массив;
	ОпасныеГрузы      = Новый Массив;	
	СведенияГосСистем = Новый Массив;	
	
	Отбор = Новый Структура;
	Отбор.Вставить("КлючСтроки_Грузы", КлючСтроки);
	
	// Контейнеры
	НайденныеСтроки = РеквизитыОбъекта.Контейнеры.НайтиСтроки(Отбор);
	Для Каждого Контейнер Из НайденныеСтроки Цикл 
		
		Структура = Новый Структура;
		Структура.Вставить("Номер", Контейнер.Номер);
		
		Контейнеры.Добавить(Структура);
		
	КонецЦикла;	
	// -
	
	// Маркировка
	НайденныеСтроки = РеквизитыОбъекта.Маркировки.НайтиСтроки(Отбор);
	Для Каждого Маркировка Из НайденныеСтроки Цикл 
		
		Структура = Новый Структура;
		Структура.Вставить("Значение", Маркировка.Значение);
		
		Маркировки.Добавить(Структура);
				
	КонецЦикла;
	// -
	
	// Опасный груз
	КолонкиИсключение = Новый Массив;
	КолонкиИсключение.Добавить("Класс");
	КолонкиИсключение.Добавить("ГруппаУпаковки"); 
	КолонкиИсключение.Добавить("ОграничениеТуннели");
	КолонкиИсключение.Добавить("ОпасныйГруз");
	
	НайденныеСтроки = РеквизитыОбъекта.ОпасныеГрузы.НайтиСтроки(Отбор);
	Для Каждого Опасный Из НайденныеСтроки Цикл 
		
		// минимальный набор атрибутов
		ПараметрыСтроки = СтрокаТаблицыЗначенийВСтруктуру(Опасный, КолонкиИсключение);
		
		ПараметрыСтроки.Вставить("Класс",              ЗначениеКлассОпасности(Опасный.Класс));
		ПараметрыСтроки.Вставить("ГруппаУпаковки",     СокрЛП(Опасный.ГруппаУпаковки));
		ПараметрыСтроки.Вставить("ОграничениеТуннели", ЗначениеОграниченияТуннели(Опасный.ОграничениеТуннели));
				
		ОпасныеГрузы.Добавить(ПараметрыСтроки);
				
	КонецЦикла;
	// -
	
	// ГосСистемы
	НайденныеСтроки = РеквизитыОбъекта.СведенияГосСистем.НайтиСтроки(Отбор);
	Для Каждого Сведения Из НайденныеСтроки Цикл 
		
		Структура = Новый Структура; 
		Структура.Вставить("Наименование",     Сведения.НаименованиеГосСистемы);
		Структура.Вставить("УчетнаяЕдиница",   Сведения.УчетнаяЕдиница);
		Структура.Вставить("ДругаяИнформация", Сведения.ИнаяИнформация);
		Структура.Вставить("Идентификатор",    "");
		
		СведенияГосСистем.Добавить(Структура);
				
	КонецЦикла;
	// -
	
	СтруктураДанных = Новый Структура;
	СтруктураДанных.Вставить("Контейнеры",        Контейнеры);
	СтруктураДанных.Вставить("Маркировки",        Маркировки);
	СтруктураДанных.Вставить("ОпасныеГрузы",      ОпасныеГрузы);
	СтруктураДанных.Вставить("СведенияГосСистем", СведенияГосСистем);
	
	Возврат СтруктураДанных;
		
КонецФункции

Функция СтруктураПозицииГруза()  
	
	СтруктураГруза = Новый Структура;
	СтруктураГруза.Вставить("Наименование",       "");
	СтруктураГруза.Вставить("Код",                "");
	СтруктураГруза.Вставить("Состояние",          "");
	СтруктураГруза.Вставить("Упаковка",           "");
	СтруктураГруза.Вставить("Тара",               "");
	СтруктураГруза.Вставить("Плотность",          0);
	СтруктураГруза.Вставить("Объем",              0);
	СтруктураГруза.Вставить("Количество",         0);
	СтруктураГруза.Вставить("УчетГИС",            Ложь);
	СтруктураГруза.Вставить("ДопИнформация",      "");
	СтруктураГруза.Вставить("Высота",             0);
	СтруктураГруза.Вставить("Длина",              0);
	СтруктураГруза.Вставить("Ширина",             0);
	СтруктураГруза.Вставить("МассаНетто",         0);
	СтруктураГруза.Вставить("МассаБрутто",        0);
	СтруктураГруза.Вставить("КоличествоПаллет",   0);
	СтруктураГруза.Вставить("СтоимостьСНалогом",  0);
	СтруктураГруза.Вставить("КодВалюты",          "");
	СтруктураГруза.Вставить("НаименованиеВалюты", "");
	СтруктураГруза.Вставить("Заказчик",           "");
	
	Возврат СтруктураГруза;
	
КонецФункции

#КонецОбласти 

#Область СопроводительныеДокументы

Функция СопроводительныеДокументы(РеквизитыОбъекта)
	
	// Все сопроводительные документы    	
	ТЗ_СопрДокументы = РеквизитыОбъекта.СопроводительныеДокументы;
	СопрВедомость    = РеквизитыОбъекта.Отправитель_СопроводительнаяВедомость;
	ДоговорПеревозки = РеквизитыОбъекта.Заказчик_Договор;
	
	КГрузу       = Новый Массив;
	КТрН         = Новый Массив;
	ПередачиЦенн = Новый Массив;
	
	// получаем данные всех документов
	// за 1 раз
	Массив = Новый Массив;
	
	Если ЗначениеЗаполнено(СопрВедомость) Тогда 
		Массив.Добавить(СопрВедомость);		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДоговорПеревозки) Тогда 
		Массив.Добавить(ДоговорПеревозки);
	КонецЕсли;
		
	// К грузу, К ТрН, передачи ценностей
	Для Каждого Строка Из ТЗ_СопрДокументы Цикл
		Массив.Добавить(Строка.Документ);	
	КонецЦикла;
		
	//////////////////////////////////////////////
	// Обработка полученных данных 	
	Соответствие = РеквизитыДокументовСбис(Массив);
	Для Каждого Строка Из ТЗ_СопрДокументы Цикл   
		
		Данные = Соответствие.Получить(Строка.Документ);
		
		Данные.Удалить("Ссылка");
		Если Данные.Тип = Перечисления.Saby_ТипыДокумента.КГрузу Тогда
			КГрузу.Добавить(Данные);
		ИначеЕсли Данные.Тип = Перечисления.Saby_ТипыДокумента.ПередачиЦенностей Тогда
		    ПередачиЦенн.Добавить(Данные);					
		Иначе 	
			// Общие к Транспортной накладной 
		    КТрН.Добавить(Данные);				
		КонецЕсли; 
		
		Данные.Удалить("Тип");
		
	КонецЦикла;	
	
	// заполняем данные документов
	ДокВедомость = "";
	Если ЗначениеЗаполнено(СопрВедомость) Тогда 
		ДокВедомость = Соответствие.Получить(СопрВедомость);
		ДокВедомость.Удалить("Ссылка");
		ДокВедомость.Удалить("Тип");
	КонецЕсли;	  
	
	ДогПеревозки = "";
	Если ЗначениеЗаполнено(ДоговорПеревозки) Тогда 
		ДогПеревозки = Соответствие.Получить(ДоговорПеревозки);
		ДогПеревозки.Удалить("Ссылка");
		ДогПеревозки.Удалить("Тип");
	КонецЕсли;		
    //
		
	Структура = Новый Структура;
	Структура.Вставить("РасчетПеревозки",           "");
	Структура.Вставить("УслугиПеревозки",           ДогПеревозки);	
	Структура.Вставить("СопровождениеТН",           КТрН);   //* 	
	Структура.Вставить("Груз",                      КГрузу); //*		
	Структура.Вставить("Отгрузка",                  ПередачиЦенн); //*
	Структура.Вставить("СопроводительнаяВедомость", ДокВедомость);
	
    Возврат Структура;

КонецФункции

#КонецОбласти  

#Область Транспорт

Функция ДанныеТС(ТС)
		
	Структура = СтруктураДанныхТС();
	Если Не ЗначениеЗаполнено(ТС) Тогда 
		Возврат Структура;
	КонецЕсли;
		
	// ToDo: 1 общий запрос данных по всем ТС
	
	Массив = Новый Массив;
	Массив.Добавить("Код"); // РегНомер
	Массив.Добавить("Тип.Наименование");
	Массив.Добавить("Марка"); 
	Массив.Добавить("ГрузоподъемностьВТоннах");
	Массив.Добавить("ВместимостьВКубическихМетрах");
	//Массив.Добавить("ГосударственныйНомерПрицепа");
	Массив.Добавить("НомерСТС");
	Массив.Добавить("VIN"); 
	Массив.Добавить("ТипВладения");
	Массив.Добавить("ДокументыПодтверждающиеВладение");
	
	РеквизитыТС = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ТС, Массив);
	ЗаполнитьЗначенияСвойств(Структура, РеквизитыТС);
	
	Структура.РегНомер         = РеквизитыТС.Код;
	Структура.НомерСТС         = РеквизитыТС.НомерСТС;
	Структура.Тип              = ?(ЗначениеЗаполнено(РеквизитыТС.ТипНаименование), РеквизитыТС.ТипНаименование, "");
	Структура.ТипВладения      = ТипВладенияТС(РеквизитыТС.ТипВладения);
	Структура.Грузоподъемность = РеквизитыТС.ГрузоподъемностьВТоннах;
	Структура.Вместимость      = РеквизитыТС.ВместимостьВКубическихМетрах;
		
	МассивДокументов = РеквизитыТС.ДокументыПодтверждающиеВладение.Выгрузить().ВыгрузитьКолонку("ДокументВладения");	
	Если МассивДокументов.Количество() Тогда 
				
		ДанныеДокументов = РеквизитыДокументовСбис(МассивДокументов);
		Для Каждого ДокВладения Из МассивДокументов Цикл
			
			ДанныеДок = ДанныеДокументов.Получить(ДокВладения);
			ДанныеДок.Удалить("Тип");
			
			Структура.ОснованиеВладения.Добавить(ДанныеДок);
			
		КонецЦикла;
				
	КонецЕсли;
		
	Возврат Структура;
	
КонецФункции

Функция ТипВладенияТС(Значение)
		
	Соответствие = Новый Соответствие;
	Соответствие.Вставить(Перечисления.Saby_ТипыВладенияТС.Собственность,                   "Собственность");
	Соответствие.Вставить(Перечисления.Saby_ТипыВладенияТС.СовместнаяСобственностьСупругов, "СовместнаяСобственностьСупругов");
	Соответствие.Вставить(Перечисления.Saby_ТипыВладенияТС.Аренда,                          "Аренда");
	Соответствие.Вставить(Перечисления.Saby_ТипыВладенияТС.Лизинг,                          "Лизинг");
	Соответствие.Вставить(Перечисления.Saby_ТипыВладенияТС.БезвозмездноеПользование,        "БезвозмездноеПользование"); 
	
	ТипВладения = Соответствие.Получить(Значение);
	Если ТипВладения = Неопределено Тогда 
		ТипВладения = "";
	КонецЕсли;
		
	Возврат ТипВладения;
	
КонецФункции

Функция СтруктураДанныхТС()
		
	Структура = Новый Структура;
	Структура.Вставить("НомерСТС",          "");
	Структура.Вставить("VIN",               "");
	Структура.Вставить("РегНомер",          "");
	Структура.Вставить("ТипВладения",       ""); 
	Структура.Вставить("Тип",               "");		
	Структура.Вставить("Марка",             "");
	Структура.Вставить("Грузоподъемность",  0);
	Структура.Вставить("Вместимость",       0);
	Структура.Вставить("ОснованиеВладения", Новый Массив);
	//Структура.Вставить("Прицепы",          Новый Массив);
	//Структура.Вставить("СпецРазрешения",   Новый Массив);
	
	Возврат Структура;
	
КонецФункции

Функция ДанныеОВодителях(ТЗ_Водители)	
	
	МассивВодителей = Новый Массив;
	
	Водители = ТЗ_Водители.ВыгрузитьКолонку("Водитель");
	
	МассивРеквизитов = Новый Массив;
	МассивРеквизитов.Добавить("Фамилия");
	МассивРеквизитов.Добавить("Имя");
	МассивРеквизитов.Добавить("Отчество");	
	МассивРеквизитов.Добавить("ИНН");
	МассивРеквизитов.Добавить("КонтактнаяИнформация");
		
	РеквизитыВодителей = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(Водители, МассивРеквизитов);
	
	// получение данных по ВУ водителей. хранятся в типовом РС ДокументыФизЛиц
	ДанныеВУВодителей = ДанныеВУВодителей(Водители); 
		
	Для Каждого Строка Из Водители Цикл 
		
		ДанныеВодителя = РеквизитыВодителей.Получить(Строка);
				
		ДанныеВодителя.Вставить("НомерВУ",      "");
		ДанныеВодителя.Вставить("СерияВУ",      "");
		ДанныеВодителя.Вставить("ДатаВыдачиВУ", "");
		ДанныеВодителя.Вставить("СведенияПЭП" , "");
	    ДанныеВодителя.Вставить("ПутевойЛист",  "");
	
		// ВУ
		ДанныеВУ = ДанныеВУВодителей.Получить(Строка);
		Если ДанныеВУ = Неопределено Тогда 			
			
			ДанныеВодителя.НомерВУ      = ДанныеВУ.Номер;
			ДанныеВодителя.СерияВУ      = ДанныеВУ.Серия;
			ДанныеВодителя.ДатаВыдачиВУ = ДанныеВУ.ДатаВыдачи;	
			
		КонецЕсли;
		// -
		
		// Телефоны
		МассивТелефонов = Новый Массив;
		
		КИВыборка = ДанныеВодителя.КонтактнаяИнформация.Выбрать();		
		Пока КИВыборка.Следующий() Цикл
			Если КИВыборка.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда 
				МассивТелефонов.Добавить(КИВыборка.Представление);
			КонецЕсли;		
		КонецЦикла;
				
		УдалитьРеквизиты = Новый Массив();
		УдалитьРеквизиты.Добавить("КонтактнаяИнформация");
		УдалитьСвойстваИзСтруктуры(ДанныеВодителя, УдалитьРеквизиты);
				
		ДанныеВодителя.Вставить("Телефон", МассивТелефонов);
		// -
		
		МассивВодителей.Добавить(ДанныеВодителя);
		
	КонецЦикла;
	
	Возврат МассивВодителей;
	
КонецФункции	

Функция ДанныеВУВодителей(Водители)
	
	Запрос = Новый Запрос; 
	Запрос.УстановитьПараметр("Дата",     ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("Водители", Водители);
	Запрос.УстановитьПараметр("ВУ",       Справочники.ВидыДокументовФизическихЛиц.ВодительскоеУдостоверение);
	
	Запрос.Текст = 
	"	ВЫБРАТЬ
	|	ДокументыФизическихЛицСрезПоследних.Физлицо КАК Физлицо,
	|	ДокументыФизическихЛицСрезПоследних.ВидДокумента КАК ВидДокумента,
	|	ДокументыФизическихЛицСрезПоследних.Серия КАК Серия,
	|	ДокументыФизическихЛицСрезПоследних.Номер КАК Номер,
	|	ДокументыФизическихЛицСрезПоследних.ДатаВыдачи КАК ДатаВыдачи,
	|	ДокументыФизическихЛицСрезПоследних.КатегорииТранспортныхСредств КАК КатегорииТранспортныхСредств
	|ИЗ
	|	РегистрСведений.ДокументыФизическихЛиц.СрезПоследних(
	|			&Дата,
	|			ВидДокумента = &ВУ
	|				И Физлицо В (&Водители)) КАК ДокументыФизическихЛицСрезПоследних";
		
	// Данные ВУ		
	Выборка = Запрос.Выполнить().Выбрать(); 
	
	Соответствие = Новый Соответствие;
	Пока Выборка.Следующий() Цикл 
		
		Структура = Новый Структура;
		Структура.Вставить("Номер",      Выборка.Номер);
		Структура.Вставить("Серия",      Выборка.Серия);
		Структура.Вставить("ДатаВыдачи", Выборка.ДатаВыдачи);
		
		Соответствие.Вставить(Выборка.Физлицо, Структура);
				
	КонецЦикла;

	Возврат Соответствие;
	
КонецФункции

Функция ДанныеПрицепов(ТЗ_Прицепы)
	
	МассивПрицепы = Новый Массив;
	
	Для Каждого Строка Из ТЗ_Прицепы Цикл
		
		ДанныеПрицепа = ДанныеТС(Строка.Прицеп);
		
		МассивПрицепы.Добавить(ДанныеПрицепа);
		
	КонецЦикла;
	
	Возврат МассивПрицепы;
	
КонецФункции

Функция СпецРазрешения(ТЗ_СпецРазрешения)
	
	МассивРазрешений = Новый Массив;   
	
	КолонкиИсключения = Новый Массив;
	КолонкиИсключения.Добавить("ИД");
	
	Для Каждого Строка Из ТЗ_СпецРазрешения Цикл
		
	   ПараметрыСтроки = СтрокаТаблицыЗначенийВСтруктуру(Строка, КолонкиИсключения);
	   //ПараметрыСтроки.Вставить("Идентификатор",         "");
	   ПараметрыСтроки.Вставить("Маршрут",               "");
	   ПараметрыСтроки.Вставить("МаршрутМашиночитаемый", "");
	   ПараметрыСтроки.Вставить("ДопСведенияТС",         "");
	   
	   МассивРазрешений.Добавить(ПараметрыСтроки);
	   
	КонецЦикла;
	
	Возврат МассивРазрешений;
	
КонецФункции

#КонецОбласти 

#Область Отметки

Функция ОтметкиДокумента(РеквизитыОбъекта, Отбор = Неопределено)
	
	// Предусмотрим вариант отбора 
	// - титулу 
	// - роли контрагента
	Если Отбор = Неопределено Тогда 
		Отметки = РеквизитыОбъекта.Отметки;
	Иначе 
		Отметки = РеквизитыОбъекта.Отметки.НайтиСтроки(Отбор);
	КонецЕсли;
	
	КолонкиИсключение = Новый Массив;
	КолонкиИсключение.Добавить("НомерСтроки");
	КолонкиИсключение.Добавить("Этап");
	КолонкиИсключение.Добавить("Роль");
	КолонкиИсключение.Добавить("КлючСтроки"); 
	
	МассивОтметок = Новый Массив;
	
	Для Каждого Строка Из Отметки Цикл  
		
		ПараметрыСтроки = СтрокаТаблицыЗначенийВСтруктуру(Строка, КолонкиИсключение);
		ПараметрыСтроки.Вставить("Участник", УчастникЭтапаОтметки(Строка.Этап));
		
		АктыИШтрафы = АктыИШтрафы(Строка.КлючСтроки, РеквизитыОбъекта);
		
		КоличествоАкты = 
		АктыИШтрафы.АктыВзвешивания.Количество() + АктыИШтрафы.АктыКоммерческие.Количество(); 
		
		ПараметрыСтроки.Вставить("КоличествоАктов",   КоличествоАкты);
		ПараметрыСтроки.Вставить("КоличествоШтрафов", АктыИШтрафы.Штраф.Количество());
		
		ПараметрыСтроки.Вставить("АктыВзвешивания",  АктыИШтрафы.АктыВзвешивания);
		ПараметрыСтроки.Вставить("АктыКоммерческие", АктыИШтрафы.АктыКоммерческие);
		ПараметрыСтроки.Вставить("Штрафы",           АктыИШтрафы.Штраф);
		 		
		МассивОтметок.Добавить(ПараметрыСтроки);
		
	КонецЦикла;
	
	Возврат МассивОтметок;
	
КонецФункции

Функция УчастникЭтапаОтметки(Этап)
	
	СоответствиеЭтапов = Новый Соответствие;
	СоответствиеЭтапов.Вставить(Перечисления.Saby_ТипТитулаЭтрН.Погрузка, "Т1");
	СоответствиеЭтапов.Вставить(Перечисления.Saby_ТипТитулаЭтрН.ПолучениеГруза, "Т2");
	СоответствиеЭтапов.Вставить(Перечисления.Saby_ТипТитулаЭтрН.ПриемкаГруза, "Т3");
	СоответствиеЭтапов.Вставить(Перечисления.Saby_ТипТитулаЭтрН.ВыдачаГруза, "Т4");
	   
   	УчастникЭтапа = СоответствиеЭтапов.Получить(Этап);
	Если УчастникЭтапа = Неопределено Тогда 
		Возврат "";
	КонецЕсли;
	
    Возврат УчастникЭтапа;
		
КонецФункции

Функция АктыИШтрафы(КлючСтроки, РеквизитыОбъекта)
	
	МассивАкты    = Новый Массив; 
	МассивАктыКом = Новый Массив;
    МассивШтрафы  = Новый Массив;
			
	КолонкиИсключение = Новый Массив;
	КолонкиИсключение.Добавить("НомерСтроки");
	КолонкиИсключение.Добавить("КлючСтроки_Отметки");
	
	Отбор = Новый Структура;
	Отбор.Вставить("КлючСтроки_Отметки", КлючСтроки);
	
	МассивАктовРасчет = Новый Массив;
	
	НайденныеСтроки = РеквизитыОбъекта.Акты.НайтиСтроки(Отбор);
	Для Каждого Строка Из НайденныеСтроки Цикл 		
		МассивАктовРасчет.Добавить(Строка.Документ);	
	КонецЦикла;
	
	ДанныеДокументов = РеквизитыДокументовСбис(МассивАктовРасчет);
	Для Каждого Док Из МассивАктовРасчет Цикл
		
		ДанныеАкта = ДанныеДокументов.Получить(Док);
		Если ДанныеАкта.Тип = Перечисления.Saby_ТипыДокумента.АктВзвешивания Тогда 
		    МассивАкты.Добавить(ДанныеАкта);
		Иначе 
			МассивАктыКом.Добавить(ДанныеАкта);
		КонецЕсли;
					
		ДанныеАкта.Удалить("Тип");
		ДанныеАкта.Удалить("Ссылка");
				
	КонецЦикла;
			
    НайденныеСтроки = РеквизитыОбъекта.Штрафы.НайтиСтроки(Отбор);
	
	КолонкиИсключение.Добавить("СуммаВВалюте");
	КолонкиИсключение.Добавить("Курс");
	КолонкиИсключение.Добавить("Валюта");
	
	Для Каждого Строка Из НайденныеСтроки Цикл 
		
		ПараметрыСтроки = СтрокаТаблицыЗначенийВСтруктуру(Строка, КолонкиИсключение);		
		МассивШтрафы.Добавить(ПараметрыСтроки);               
		
	КонецЦикла;
	
	Структура = Новый Структура; 
	Структура.Вставить("АктыКоммерческие", МассивАктыКом);
	Структура.Вставить("АктыВзвешивания",  МассивАкты);
	Структура.Вставить("Штраф",            МассивШтрафы);
		
	Возврат Структура;
	
КонецФункции

#КонецОбласти

#Область Этапы

Функция ДанныеДоставки(РеквизитыОбъекта) 
	
	Структура = Новый Структура;
	
	// Погрузка
	СтруктураПогрузка = Новый Структура;
	
	СтруктураПогрузка.Вставить("ОснованиеДоступа",  ""); // ???
	СтруктураПогрузка.Вставить("ДатаВремяПодачи",   РеквизитыОбъекта.Погрузка_ДатаВремя);
	СтруктураПогрузка.Вставить("ДатаВремяПрибытия", РеквизитыОбъекта.Погрузка_ДатаВремяПрибыл);
	СтруктураПогрузка.Вставить("ДатаВремяУбытия",   РеквизитыОбъекта.Погрузка_ДатаВремяУбыл);
	СтруктураПогрузка.Вставить("СостояниеТары",     СокрЛП(РеквизитыОбъекта.Погрузка_Состояние));	
	СтруктураПогрузка.Вставить("СостояниеУпаковки", "");
	СтруктураПогрузка.Вставить("СостояниеКузова",   "");
	СтруктураПогрузка.Вставить("МассаБрутто",       РеквизитыОбъекта.Погрузка_Масса);
	СтруктураПогрузка.Вставить("ОпределениеМассы",  ЗначениеМетодаОпределенияМассы(РеквизитыОбъекта.Погрузка_МассаМетодРасчета));  
	СтруктураПогрузка.Вставить("ГрузовыеМеста",     РеквизитыОбъекта.Погрузка_КоличествоМест);		
    СтруктураПогрузка.Вставить("ЛицоПогрузки",      ДанныеЮрЛица("Отгрузчик", РеквизитыОбъекта));
	
	СтруктураАдреса       = СтруктураАдресаОтправкиДоставки();
	СтруктураАдреса.Адрес = РеквизитыОбъекта.Погрузка_Адрес;	
	СтруктураПогрузка.Вставить("Адрес", СтруктураАдреса);    	
	// -
	
	// Условия перевозки
    СтруктураУсловия = Новый Структура;
	
	СтруктураУсловия.Вставить("Перегрузка",             Не РеквизитыОбъекта.Отправитель_ПерегрузкаЗапрешена);
	СтруктураУсловия.Вставить("ДатаВремяДоставки",      РеквизитыОбъекта.Отправитель_ДоставитьДо);
	СтруктураУсловия.Вставить("СрокДоставки",           РеквизитыОбъекта.Отправитель_ДоставитьСрок);
	СтруктураУсловия.Вставить("Пломба",                 РеквизитыОбъекта.Отправитель_Пломба);
	СтруктураУсловия.Вставить("Нормы",                  РеквизитыОбъекта.Отправитель_НормыПеревозки);
	СтруктураУсловия.Вставить("Скорость",               РеквизитыОбъекта.Отправитель_ОграничениеСкорости);
	СтруктураУсловия.Вставить("Маршрут",                "");
	СтруктураУсловия.Вставить("МаршрутМашиночитаемый",  "");			 
	// -
	
	// Климатический режим
	СтруктураКлимат = Новый Структура;
	СтруктураКлимат.Вставить("ТемператураОт",  РеквизитыОбъекта.Отправитель_ТемператураОт);
	СтруктураКлимат.Вставить("ТемператураДо",  РеквизитыОбъекта.Отправитель_ТемператураДо);
	СтруктураКлимат.Вставить("ВлажностьОт",    РеквизитыОбъекта.Отправитель_ВлажностьОт);
	СтруктураКлимат.Вставить("ВлажностьДо",    РеквизитыОбъекта.Отправитель_ВлажностьДо);
	// -
	
	//СтруктураУсловия.Вставить("Переадресация",          ""); СокрЛП(РеквизитыОбъекта.Отправитель_ИнициаторПереадресации));
				
	// Владелец объекта погрузки	
	////ВладелецТип = РеквизитыОбъекта.Владелец_Тип;	
	////Структура.Вставить("ВладелецЭтоОтправитель", ВладелецТип = Перечисления.Saby_ВладелецОбъектаОтгрузки.Отправитель);    

	////Если ВладелецТип = Перечисления.Saby_ВладелецОбъектаОтгрузки.Неизвестен Тогда   
	////    Структура.Вставить("ВладелецОбъекта", "");
	////	Структура.Вставить("НеизвестенПричина", СокрЛП(РеквизитыОбъекта.Владелец_НеизвестенПричина));
	////Иначе 			
	////	Структура.Вставить("ВладелецОбъекта", ДанныеЮрЛица("ВладелецОбъекта", РеквизитыОбъекта)); 
	////	Структура.Вставить("НеизвестенПричина", "");
	////КонецЕсли;
	// -
	
	Структура.Вставить("Погрузка",           СтруктураПогрузка);
	Структура.Вставить("УсловияПеревозки",   СтруктураУсловия);
	Структура.Вставить("Переадресовка",      "");
	Структура.Вставить("КлиматическийРежим", СтруктураКлимат);
	
	Возврат Структура;
	
КонецФункции

Функция ДанныеПогрузки(РеквизитыОбъекта) 
	
	Структура = Новый Структура;
		
	Структура.Вставить("ДатаВремяПрибытия",       РеквизитыОбъекта.Перевозчик_ПриемкаДатаВремяПрибыл);
	Структура.Вставить("ДатаВремяНачалаПогрузки", РеквизитыОбъекта.Перевозчик_ПриемкаДатаВремя);
	Структура.Вставить("ДатаВремяУбытия",         РеквизитыОбъекта.Перевозчик_ПриемкаДатаВремяУбыл);

	// Замечания
	Структура.Вставить("ЗамечаниеСостояние",  СокрЛП(РеквизитыОбъекта.Перевозчик_ПогрузкаЗамечанияПоСостояниюГруза));
	Структура.Вставить("ЗамечаниеПоРаботам",  СокрЛП(РеквизитыОбъекта.Перевозчик_ЗамечанияПоПогрузочнымРаботам));
	Структура.Вставить("ЗамечаниеКоличество", СокрЛП(РеквизитыОбъекта.Перевозчик_ПогрузкаЗамечанияПоКоличеству));
	Структура.Вставить("ЗамечаниеМасса",      СокрЛП(РеквизитыОбъекта.Перевозчик_ПогрузкаЗамечанияПоМассе));
					
	Возврат Структура;
	
КонецФункции

Функция ДанныеПриемки(РеквизитыОбъекта) 
	
	Структура = Новый Структура;
		
	Структура.Вставить("ДатаВремяПлан",        РеквизитыОбъекта.Выгрузка_ДатаВремя);
	Структура.Вставить("ДатаВремяПрибытия",    РеквизитыОбъекта.Выгрузка_ДатаВремяПрибыл);
	Структура.Вставить("ДатаВремяУбытия",      РеквизитыОбъекта.Выгрузка_ДатаВремяУбыл);

	Структура.Вставить("АдресВыгрузки",        РеквизитыОбъекта.Выгрузка_Адрес);
	
	// Состояние
	Структура.Вставить("СостояниеОбщее",       СокрЛП(РеквизитыОбъекта.Выгрузка_Состояние));

	Структура.Вставить("ОтказВПриемке",        РеквизитыОбъекта.Приемка_Отказ);
	Структура.Вставить("ОтказВПриемкеПричина", РеквизитыОбъекта.Приемка_ОтказПричина);

	Структура.Вставить("МассаБрутто",          РеквизитыОбъекта.Выгрузка_МассаБрутто);
	Структура.Вставить("МетодОпределения",     ЗначениеМетодаОпределенияМассы(РеквизитыОбъекта.Выгрузка_МассаМетодРасчета));
	Структура.Вставить("Количество",           РеквизитыОбъекта.Выгрузка_КоличествоМест);
	// МассаНетто
	// Объем
			
	Возврат Структура;
	
КонецФункции

Функция ДанныеВыдачи(РеквизитыОбъекта) 
	
	Структура = Новый Структура;
		
	Структура.Вставить("ДатаВремяПрибытия",       РеквизитыОбъекта.Перевозчик_ВыгрузкаДатаВремяПрибыл);
	Структура.Вставить("ДатаВремяНачалаПогрузки", РеквизитыОбъекта.Перевозчик_ВыгрузкаДатаВремя);
	Структура.Вставить("ДатаВремяУбытия",         РеквизитыОбъекта.Перевозчик_ВыгрузкаДатаВремяУбыл);

	Структура.Вставить("АдресВыгрузки",           РеквизитыОбъекта.Выгрузка_Адрес);

	// Состояние
	Структура.Вставить("ЗамечаниеСостояниеГруза", СокрЛП(РеквизитыОбъекта.Перевозчик_ВыгрузкаЗамечанияПоСостояниюГруза));
	Структура.Вставить("ЗамечаниеПоРаботам",      СокрЛП(РеквизитыОбъекта.Перевозчик_ЗамечанияПоРазгрузочнымРаботам));

	//Структура.Вставить("МассаБрутто",             РеквизитыОбъекта.Выгрузка_МассаБрутто);
	//Структура.Вставить("МетодОпределения",        СокрЛП(РеквизитыОбъекта.Выгрузка_МассаМетодРасчета));
	//Структура.Вставить("Количество",              РеквизитыОбъекта.Выгрузка_КоличествоМест);
	// МассаНетто
	// Объем
		
	
	Возврат Структура;
	
КонецФункции

#КонецОбласти

Функция РеквизитыДокументовСбис(МассивДокументов)
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивСсылок", МассивДокументов);
	
	Запрос.Текст =	
	"ВЫБРАТЬ
	|	ДокументыТрН.Наименование КАК Наименование,
	|	ДокументыТрН.Номер КАК НомерДокумента,
	|	ДокументыТрН.Дата КАК ДатаДокумента,
	|	ДокументыТрН.ДопСведения КАК ДополнительныеСведения,
	|	ДокументыТрН.Ссылка КАК Ссылка,
	|	ДокументыТрН.Тип КАК Тип
	|ИЗ
	|	Справочник.Saby_ДокументыТрН КАК ДокументыТрН
	|ГДЕ
	|	ДокументыТрН.Ссылка В(&МассивСсылок)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДокументыТрНСтороны.Ссылка КАК Ссылка,
	|	ДокументыТрНСтороны.Сторона КАК Сторона,
	|	ДокументыТрНСтороны.Сторона.Наименование КАК Наименование,
	|	ДокументыТрНСтороны.Сторона.ИНН КАК ИНН,
	|	ДокументыТрНСтороны.Сторона.КПП КАК КПП,
	|	ДокументыТрНСтороны.Сторона.СтранаРегистрации КАК Страна, 
	|   ВЫБОР 
	|   КОГДА ТИПЗНАЧЕНИЯ(Сторона) = ТИП(Справочник.Организации) ТОГДА
	|       Сторона.ОГРН
	|   КОГДА ТИПЗНАЧЕНИЯ(Сторона) = ТИП(Справочник.Контрагенты) ТОГДА  
	|       Сторона.РегистрационныйНомер
	|   ИНАЧЕ
	|       """"
	|   КОНЕЦ КАК ОГРН,
	|	ДокументыТрНСтороны.Сторона.ЮрФизЛицо КАК ЮрФизЛицо
	|ИЗ
	|	Справочник.Saby_ДокументыТрН.Стороны КАК ДокументыТрНСтороны
	|ГДЕ
	|	ДокументыТрНСтороны.Ссылка В(&МассивСсылок)";
		
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаДокументов = РезультатЗапроса[0].Выбрать();
	РеквизитыСторон   = РезультатЗапроса[1].Выгрузить();
				
	Соответствие = Новый Соответствие;
	
	КолонкиИсключения = Новый Массив;
	КолонкиИсключения.Добавить("Ссылка");
	//КолонкиИсключения.Добавить("Тип");	
	
	Пока ВыборкаДокументов.Следующий() Цикл 
		
		ПараметрыСтроки = СтрокаТаблицыЗначенийВСтруктуру(ВыборкаДокументов, КолонкиИсключения);	
		
		// добавим стороны документа                   
		Отбор = Новый Структура;
		Отбор.Вставить("Ссылка", ВыборкаДокументов.Ссылка);
		
		МассивСторон = Новый Массив;                 
				
		НайденныеСтроки = РеквизитыСторон.НайтиСтроки(Отбор);
		Для Каждого Сторона Из НайденныеСтроки Цикл
			
			ПараметрыСтороны = Новый Структура;
			ПараметрыСтороны.Вставить("Наименование", Сторона.Наименование);
			ПараметрыСтороны.Вставить("ИННЮЛ", "");
			ПараметрыСтороны.Вставить("ИННФЛ", "");
			
			СтруктураИнЛица = СтруктураИностранногоЛица();
			
			Если Сторона.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо Тогда
				
				ПараметрыСтороны.ИННЮЛ = Сторона.ИНН;
							
			ИначеЕсли Сторона.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицоНеРезидент Тогда 
				
				ПараметрыСтороны.ИННЮЛ       = Сторона.ИНН;
				СтруктураИнЛица.Страна       = СокрЛП(Сторона.Страна);
				СтруктураИнЛица.Наименование = Сторона.Наименование;
				
			Иначе  
				
				// Физ или ИП
				ПараметрыСтороны.ИННФЛ = Сторона.ИНН;
				
			КонецЕсли;
							
			ПараметрыСтороны.Вставить("ИностранноеЛицо", СтруктураИнЛица);			
			
			МассивСторон.Добавить(ПараметрыСтороны);
			
		КонецЦикла;
		
		ПараметрыСтроки.Вставить("Стороны", МассивСторон);
		
		Соответствие.Вставить(ВыборкаДокументов.Ссылка, ПараметрыСтроки);
				
	КонецЦикла;
	
	Возврат Соответствие;
	
КонецФункции
	
#КонецОбласти

#Область СобратьДокументИзJson

Функция ЗагрузкаДанныхДокумента(JSONСтрокой) Экспорт
		
 	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(JSONСтрокой);  		
	ИсходнаяСтруктура = ПрочитатьJSON(ЧтениеJSON);
	
	// Разберем структуру
	СоздатьНовыйДокумент = Ложь;
	
	// Поиск есть ли в базе 1С уже такой документ
	СсылкаДокВБазе = Документы.Saby_ТранспортнаяНакладная.НайтиПоРеквизиту("ИД_Сбис", ИсходнаяСтруктура.ИД_Сбис); 
	Если ЗначениеЗаполнено(СсылкаДокВБазе) Тогда 		
		// нашли документ в базе
		ОбъектДок = СсылкаДокВБазе.ПолучитьОбъект(); 				
	Иначе 			
		
		// документа нет. создадим новый
		ОбъектДок = Документы.Saby_ТранспортнаяНакладная.СоздатьДокумент();		
		СоздатьНовыйДокумент = Истина;
				
	КонецЕсли;
	
	// Дополним структуру документа. Учесть этапы
	
	// Если документа в базе нет. заполняем все
	// если документ есть то заполняем все последующие этапы от текущего
	
	// ToDo: добавить работу с этапами 
	// найти текущий этап...
	ТекущийЭтап = "";
	
	Если СоздатьНовыйДокумент Тогда 
		
		// основные данные и участники документа
		ЗаполнитьДанныеШапкиДокумента(ОбъектДок, ИсходнаяСтруктура); 
		
		// ТС, Прицепы, Водители, Спец разрешения
		ЗаполнитьДанныеТранспортаИВодителейДокумента(ОбъектДок, ИсходнаяСтруктура);
		
		// СопроводВедомость, Договор перевозки, Документы к грузу, К Трн, Передачи ценностей
		ЗаполнитьДанныеДокументовТрН(ОбъектДок, ИсходнаяСтруктура.Документы);
		
		// Груз, опасный груз, контейнеры, гос системы, маркировка 
		ЗаполнитьДанныеПоГрузам(ОбъектДок, ИсходнаяСтруктура.Груз);
		
		// Отметки по всем титулам, акты и штрафы 
		ЗаполнитьДанныеПоОтметкамДокумента(ОбъектДок, ИсходнаяСтруктура.Отметки);
		
		ЗапонитьДанныеДокументаДоставки(ОбъектДок, ИсходнаяСтруктура.Доставка);
		
		//ЗапонитьДанныеПогрузки(ОбъектДок,  ИсходнаяСтруктура);
		//ЗапонитьДанныеПриемки(ОбъектДок,   ИсходнаяСтруктура);
		//ЗапонитьДанныеВыдачи(ОбъектДок,    ИсходнаяСтруктура);

	ИначеЕсли ТекущийЭтап = "Отправка" Тогда

		//ЗапонитьДанныеПогрузки(ОбъектДок,  ИсходнаяСтруктура);
		//ЗапонитьДанныеПриемки(ОбъектДок,   ИсходнаяСтруктура);
		//ЗапонитьДанныеВыдачи(ОбъектДок,    ИсходнаяСтруктура);

	ИначеЕсли ТекущийЭтап = "Погрузка" Тогда

		//ЗапонитьДанныеПриемки(ОбъектДок,   ИсходнаяСтруктура);
		//ЗапонитьДанныеВыдачи(ОбъектДок,    ИсходнаяСтруктура);
		
	ИначеЕсли ТекущийЭтап = "Приемка" Тогда 
		
		//ЗапонитьДанныеВыдачи(ОбъектДок,    ИсходнаяСтруктура);
		
	Иначе 
		
		// ТекущийЭтап = "Выдача" 		
		// находимся на последнем этапе... 
		// ни чего не нужно, возможно, в дальнейшем изменится 
		
	КонецЕсли;
	
	ОбъектДок.ОбменДанными.Загрузка = Истина;
	ОбъектДок.Записать();
	
	Возврат ОбъектДок.Ссылка;
		
КонецФункции

Процедура ЗаполнитьДанныеШапкиДокумента(ОбъектДок, ИсходнаяСтруктура)
	
	ОбъектДок.ИД_Сбис = ИсходнаяСтруктура.ИД_Сбис;

	ОбъектДок.Дата = ПрочитатьДатуJSON(ИсходнаяСтруктура.Дата, ФорматДатыJSON.ISO);	
	ОбъектДок.УстановитьНовыйНомер();
		
	// ДатаНомерЗаявки
	ОбъектДок.Отправитель_ЗаявкаНомер = ИсходнаяСтруктура.НомерЗаказа;
	ОбъектДок.Отправитель_ЗаявкаДата  = ПрочитатьДатуJSON(ИсходнаяСтруктура.ДатаЗаказа, ФорматДатыJSON.ISO);
			
	// Данные по участникам документооборота
	ОбъектДок.Отправитель = ПолучитьЮрЛицо(ИсходнаяСтруктура.Грузоотправитель); 
	ЗаполнитьДанныеЮрЛицИКонтактнуюИнформацию(
	    ОбъектДок,
		ИсходнаяСтруктура.Грузоотправитель, 
		Перечисления.Saby_РолиКонтрагентовЭтрН.Отправитель);
		
	ОбъектДок.Заказчик = ПолучитьЮрЛицо(ИсходнаяСтруктура.Заказчик);		
	ЗаполнитьДанныеЮрЛицИКонтактнуюИнформацию(
	    ОбъектДок,
	    ИсходнаяСтруктура.Заказчик, 
		Перечисления.Saby_РолиКонтрагентовЭтрН.Заказчик);
	
	ОбъектДок.Получатель  = ПолучитьЮрЛицо(ИсходнаяСтруктура.Грузополучатель);		
	ЗаполнитьДанныеЮрЛицИКонтактнуюИнформацию(
	    ОбъектДок,
	    ИсходнаяСтруктура.Грузополучатель, 
		Перечисления.Saby_РолиКонтрагентовЭтрН.Получатель);
	
	ОбъектДок.Перевозчик  = ПолучитьЮрЛицо(ИсходнаяСтруктура.Грузоперевозчик);	
	ЗаполнитьДанныеЮрЛицИКонтактнуюИнформацию(
	    ОбъектДок,
	    ИсходнаяСтруктура.Грузоперевозчик, 
		Перечисления.Saby_РолиКонтрагентовЭтрН.Перевозчик);
	
	// Тип - исходящий или входящий. 
	// Если будет загрузка из сервиса старых документов, не оформленных в 1С
	Если ТипЗнч(ОбъектДок.Отправитель) = Тип("СправочникСсылка.Организации") Тогда 
		ОбъектДок.ТипЭтрН = Перечисления.Saby_ТипЭтрНВЛокальнойБазе.Исходящий;
	Иначе 	
		ОбъектДок.ТипЭтрН = Перечисления.Saby_ТипЭтрНВЛокальнойБазе.Входящий;
	КонецЕсли;	
		
КонецПроцедуры

#Область ЗагрузкаДанныхЮрЛиц

Функция ПолучитьЮрЛицо(ДанныеЮрЛица, ЭтоСтронаДокумента = Ложь, Роль = Неопределено, ОбъектДок = Неопределено)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ЮрЛицо = Справочники.Контрагенты.ПустаяСсылка();
	Если Не ЗначениеЗаполнено(ДанныеЮрЛица.Реквизиты.ИНН) Тогда 
		Возврат ЮрЛицо;		
	КонецЕсли;
	
	Если ЭтоСтронаДокумента Тогда 
		
		ИНН = ?(ЗначениеЗаполнено(ДанныеЮрЛица.ИННЮЛ), ДанныеЮрЛица.ИННЮЛ, ДанныеЮрЛица.ИННФЛ);  
		КПП = ""; 
		
	Иначе
		
		ИНН = ДанныеЮрЛица.Реквизиты.ИНН; 
		КПП = ДанныеЮрЛица.Реквизиты.ЮЛ.КПП;
		
	КонецЕсли;	
			
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ИНН",          ИНН);
	Запрос.УстановитьПараметр("КПП",          КПП);
	Запрос.УстановитьПараметр("ПоискСтороны", ЭтоСтронаДокумента);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Организации.Ссылка КАК Ссылка,
	|	1 КАК Порядок
	|ПОМЕСТИТЬ ВТ_Данные
	|ИЗ
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	Организации.ИНН = &ИНН
	|	И ВЫБОР
	|			КОГДА &КПП = """"
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ Организации.КПП = &КПП
	|		КОНЕЦ
    |
	|ОБЪЕДИНИТЬ ВСЕ
    |
	|ВЫБРАТЬ
	|	Контрагенты.Ссылка,
	|	2
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты,
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	Контрагенты.ИНН = &ИНН
	|	И ВЫБОР
	|			КОГДА &КПП = """"
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ Контрагенты.КПП = &КПП
	|		КОНЕЦ
    |
	|ОБЪЕДИНИТЬ ВСЕ
    |
	|ВЫБРАТЬ
	|	Saby_СторонаДокумента.Ссылка,
	|	3
	|ИЗ
	|	Справочник.Saby_СторонаДокумента КАК Saby_СторонаДокумента
	|ГДЕ
	|	Saby_СторонаДокумента.ИНН = &ИНН
	|   И &ПоискСтороны = ИСТИНА 
	|;
    |
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВТ_Данные.Ссылка КАК Ссылка
	|ИЗ
	|	ВТ_Данные КАК ВТ_Данные
    |
	|УПОРЯДОЧИТЬ ПО
	|	ВТ_Данные.Порядок";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		// нашли юр.лицо. Организация, Контрагент
		ЮрЛицо = Выборка.Ссылка; 		
	Иначе
		
		Если ЭтоСтронаДокумента Тогда        
			ЮрЛицо = НоваяСторонаДокумента(ДанныеЮрЛица); 
		Иначе 	
			ЮрЛицо = НовыйКонтагент(ДанныеЮрЛица, Роль, ОбъектДок);
		КонецЕсли;
	
	КонецЕсли;	
			
	Возврат ЮрЛицо;
		
КонецФункции

Функция НовыйКонтагент(ДанныеЮрЛица, Роль, ОбъектДок)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ЗаполнятьДанныеИКИ = ЗначениеЗаполнено(Роль);
		
	// создаем контрагента...
	// по основным участникам документа
	НовоеЮрЛицо = Справочники.Контрагенты.СоздатьЭлемент();
	
	НовоеЮрЛицо.ИНН                  = ДанныеЮрЛица.ИНН;
	НовоеЮрЛицо.КПП                  = ДанныеЮрЛица.КПП;
	НовоеЮрЛицо.РегистрационныйНомер = ДанныеЮрЛица.ОГРН;
	
	ЭтоИП     = ЗначениеЗаполнено(ДанныеЮрЛица.ИП.ИНН);
	ЭтоЮЛ     = ЗначениеЗаполнено(ДанныеЮрЛица.ЮЛ.ИНН);
	//ЭтоИнЛицо = ЗначениеЗаполнено(ДанныеЮрЛица.ИностранноеЛицо.Наименование);
	ЭтоФЛ     = ЗначениеЗаполнено(ДанныеЮрЛица.ФЛ.ИНН);
	
	Если ЭтоЮЛ Тогда 
		
		НовоеЮрЛицо.Наименование       = ДанныеЮрЛица.ЮЛ.Наименование;
		НовоеЮрЛицо.НаименованиеПолное = ДанныеЮрЛица.ЮЛ.Наименование;
		НовоеЮрЛицо.ИНН                = ДанныеЮрЛица.ЮЛ.ИНН;
		НовоеЮрЛицо.КПП                = ДанныеЮрЛица.ЮЛ.КПП;
		НовоеЮрЛицо.ЮрФизЛицо          = Перечисления.ЮрФизЛицо.ЮрЛицо;
		НовоеЮрЛицо.СтранаРегистрации  = Справочники.СтраныМира.Россия;
		
		НовоеЮрЛицо.ДополнительнаяИнформация = ДанныеЮрЛица.ЮЛ.ИныеСведения;
		
	ИначеЕсли ЭтоИП Тогда 
		
		МассивНазвания = Новый Массив;
		МассивНазвания.Добавить(ДанныеЮрЛица.ИП.Фамилия);
		МассивНазвания.Добавить(ДанныеЮрЛица.ИП.Имя);
		МассивНазвания.Добавить(ДанныеЮрЛица.ИП.Отчество);
		
		Название = СтрСоединить(МассивНазвания, " ");				 
		
		НовоеЮрЛицо.ИНН                  = ДанныеЮрЛица.ИП.ИНН;
		НовоеЮрЛицо.РегистрационныйНомер = ДанныеЮрЛица.ИП.ОГРН;
		НовоеЮрЛицо.Наименование         = Название;
		НовоеЮрЛицо.НаименованиеПолное   = Название;
		НовоеЮрЛицо.ЮрФизЛицо            = Перечисления.ЮрФизЛицо.ИндивидуальныйПредприниматель;
		НовоеЮрЛицо.СтранаРегистрации    = Справочники.СтраныМира.Россия;
		
		НовоеЮрЛицо.ДополнительнаяИнформация = ДанныеЮрЛица.ИП.ИныеСведения;
		
	ИначеЕсли ЭтоФЛ Тогда
		
		МассивНазвания = Новый Массив;
		МассивНазвания.Добавить(ДанныеЮрЛица.ФЛ.Фамилия);
		МассивНазвания.Добавить(ДанныеЮрЛица.ФЛ.Имя);
		МассивНазвания.Добавить(ДанныеЮрЛица.ФЛ.Отчество);
		
		Название = СтрСоединить(МассивНазвания, " ");				 
		
		НовоеЮрЛицо.ИНН                = ДанныеЮрЛица.ФЛ.ИНН;
		НовоеЮрЛицо.Наименование       = Название;
		НовоеЮрЛицо.НаименованиеПолное = Название;				 
		НовоеЮрЛицо.ЮрФизЛицо          = Перечисления.ЮрФизЛицо.ФизЛицо;
		НовоеЮрЛицо.СтранаРегистрации  = Справочники.СтраныМира.Россия;
		
		НовоеЮрЛицо.ДополнительнаяИнформация = ДанныеЮрЛица.ФЛ.ИныеСведения;
		
	Иначе 
		
		// Иностранное лицо				 
		НовоеЮрЛицо.Наименование      = ДанныеЮрЛица.ИностранноеЛицо.Наименование;
		НовоеЮрЛицо.СтранаРегистрации = Справочники.СтраныМира.НайтиПоНаименованию(ДанныеЮрЛица.ИностранноеЛицо.Страна);	
		НовоеЮрЛицо.ЮрФизЛицо         = Перечисления.ЮрФизЛицо.ЮрЛицоНеРезидент;
		
		НовоеЮрЛицо.ДополнительнаяИнформация = ДанныеЮрЛица.ИностранноеЛицо.ИныеСведения;
		
		// ToDo: возможно это нужно где то хранить 
		// "Статус":         ???
		// "ВидДокумента":   ???
		// "НомерДокумента": ???
		// "ДатаДокумента":  ???
		
	КонецЕсли;
	
	// Юр адрес			 
	АдресКИ = НовоеЮрЛицо.КонтактнаяИнформация.Добавить();
	АдресКИ.Тип           = Перечисления.ТипыКонтактнойИнформации.Адрес;
	АдресКИ.Вид           = Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента;
	АдресКИ.Страна        = Справочники.СтраныМира.Россия; 
	АдресКИ.ДействуетС    = ТекущаяДатаСеанса();
	АдресКИ.Представление = ДанныеЮрЛица.Адрес.Юридический.Адрес;
	
	// Дополнительно. Сразу заполняем Данные ЮрЛица
	Если ЗаполнятьДанныеИКИ Тогда 
		
		НСДанныеЮЛ = ОбъектДок.ДанныеЮрЛиц.Добавить();
		
		НСДанныеЮЛ.Роль              = Роль;
		НСДанныеЮЛ.ИНН               = ДанныеЮрЛица.ИНН;
		НСДанныеЮЛ.КПП               = ДанныеЮрЛица.КПП;
		НСДанныеЮЛ.ОГРН              = ДанныеЮрЛица.ОГРН;
		НСДанныеЮЛ.ЮрФизЛицо         = НовоеЮрЛицо.ЮрФизЛицо;
		НСДанныеЮЛ.Адрес             = АдресКИ.Представление;
		НСДанныеЮЛ.АдресСтруктура    = ""; // пока не используем
		НСДанныеЮЛ.СтранаРегистрации = НовоеЮрЛицо.СтранаРегистрации;
		
		Если ЭтоИП Или ЭтоФЛ Тогда   
			
			СтруктураФИО = Новый Структура;
			СтруктураФИО.Вставить("Фамилия",  МассивНазвания[0]);
			СтруктураФИО.Вставить("Имя",      МассивНазвания[1]);
			СтруктураФИО.Вставить("Отчество", МассивНазвания[2]);
			
			ФИОСтрокой = ЗначениеВСтрокуВнутр(СтруктураФИО);
			
			НСДанныеЮЛ.СтруктураФИО = ФИОСтрокой;
			
		КонецЕсли;
			
	КонецЕсли;
	//
	
	// Телефоны
	Для Каждого Телефон Из ДанныеЮрЛица.Контакты.Телефон Цикл 
		
		ТелефонКИ = НовоеЮрЛицо.КонтактнаяИнформация.Добавить();
		ТелефонКИ.Тип           = Перечисления.ТипыКонтактнойИнформации.Телефон;
		ТелефонКИ.Вид           = Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента; 
		ТелефонКИ.ДействуетС    = ТекущаяДатаСеанса();
		ТелефонКИ.Представление = Телефон;
		ТелефонКИ.НомерТелефона = Телефон;
		
		Если ЗаполнятьДанныеИКИ Тогда
			
			НСТелефон = ОбъектДок.КонтактныеДанные.Добавить();
			НСТелефон.Роль     = Роль;
			НСТелефон.Тип      = ТелефонКИ.Тип;
		    НСТелефон.Значение = Телефон;	
			
		КонецЕсли;
				
	КонецЦикла;			 
	
	// Электронная почта
	Для Каждого ЭлПочта Из ДанныеЮрЛица.Контакты.ЭлектроннаяПочта Цикл 
		
		ЭлПочтаКИ = НовоеЮрЛицо.КонтактнаяИнформация.Добавить();
		ЭлПочтаКИ.Тип           = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
		ЭлПочтаКИ.Вид           = Справочники.ВидыКонтактнойИнформации.EmailКонтрагента; 
		ЭлПочтаКИ.ДействуетС    = ТекущаяДатаСеанса();
		ЭлПочтаКИ.Представление = ЭлПочта;
		
		Если ЗаполнятьДанныеИКИ Тогда
			
			НСЭПочта = ОбъектДок.КонтактныеДанные.Добавить();
			НСЭПочта.Роль     = Роль;
			НСЭПочта.Тип      = ЭлПочтаКИ.Тип;
			НСЭПочта.Значение = ЭлПочта;	
			
		КонецЕсли;
	
	КонецЦикла;
	
	НовоеЮрЛицо.ОбменДанными.Загрузка = Истина;
	НовоеЮрЛицо.Записать();
	
	Возврат НовоеЮрЛицо.Ссылка;
	
КонецФункции

Функция НоваяСторонаДокумента(ДанныеЮрЛица)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Сторона = Справочники.Saby_СторонаДокумента.СоздатьЭлемент();
	ЗаполнитьЗначенияСвойств(Сторона, ДанныеЮрЛица);
	
	Сторона.ИНН = ?(ЗначениеЗаполнено(ДанныеЮрЛица.ИННЮЛ), ДанныеЮрЛица.ИННЮЛ, ДанныеЮрЛица.ИННФЛ);
	
	Если ЗначениеЗаполнено(ДанныеЮрЛица.ДатаДокумента) Тогда  
		Сторона.ДатаДокумента = ПрочитатьДатуJSON(ДанныеЮрЛица.ДатаДокумента, ФорматДатыJSON.ISO);   
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Сторона.ИностранноеЛицо.Наименование) Тогда 		
		Сторона.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицоНеРезидент; 
	Иначе 
		
		Если ЗначениеЗаполнено(ДанныеЮрЛица.ИННФЛ) Тогда 
			Сторона.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо;
		Иначе
		    Сторона.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо;	
		КонецЕсли;
			
	КонецЕсли;
	
	Сторона.ОбменДанными.Загрузка = Истина;
	
	Возврат Сторона.Ссылка;
	
КонецФункции

Процедура ЗаполнитьДанныеЮрЛицИКонтактнуюИнформацию(ОбъектДок, ДанныеЮрЛица, Роль)
	
	// для иностранных возможно доп проверка
	Если Не ЗначениеЗаполнено(ДанныеЮрЛица.Реквизиты.ИНН) Тогда 
		Возврат;		
	КонецЕсли;	
	
	// если был новый контрагент
	// то данные уже заполнены если нет то заполняем 
	Отбор = Новый Структура;
	Отбор.Вставить("Роль", Роль);
	
	ДанныеЮл = ОбъектДок.ДанныеЮрЛиц.НайтиСтроки(Отбор);
	Если ДанныеЮл.Количество() Тогда 
		// данные уже есть. заполнение не требуется
		Возврат;
	КонецЕсли;
	
	// Данных нет заполняем    
	
	ЭтоИП     = ЗначениеЗаполнено(ДанныеЮрЛица.Реквизиты.ИП.ИНН);
	ЭтоЮЛ     = ЗначениеЗаполнено(ДанныеЮрЛица.Реквизиты.ЮЛ.ИНН);
	//ЭтоИнЛицо = ЗначениеЗаполнено(ДанныеЮрЛица.Реквизиты.ИностранноеЛицо.Наименование);
	ЭтоФЛ     = ЗначениеЗаполнено(ДанныеЮрЛица.Реквизиты.ФЛ.ИНН);
	
	НСДанныеЮЛ = ОбъектДок.ДанныеЮрЛиц.Добавить();
	
	НСДанныеЮЛ.Роль  = Роль;
	НСДанныеЮЛ.ИНН   = ДанныеЮрЛица.Реквизиты.ИНН;	
	НСДанныеЮЛ.Адрес = ДанныеЮрЛица.Адрес.Юридический.Адрес;
    	
	НСДанныеЮЛ.СтранаРегистрации = Справочники.СтраныМира.Россия; 
	
	Если ЭтоЮл Тогда 
		
		НСДанныеЮЛ.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо;
		НСДанныеЮЛ.КПП       = ДанныеЮрЛица.Реквизиты.ЮЛ.КПП;
		
	ИначеЕсли ЭтоФЛ Тогда 
		
		НСДанныеЮЛ.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо;
				
		СтруктураФИО = Новый Структура;
		СтруктураФИО.Вставить("Фамилия",  ДанныеЮрЛица.ФЛ.Фамилия);
		СтруктураФИО.Вставить("Имя",      ДанныеЮрЛица.ФЛ.Имя);
		СтруктураФИО.Вставить("Отчество", ДанныеЮрЛица.ФЛ.Отчество);
		
		ФИОСтрокой = ЗначениеВСтрокуВнутр(СтруктураФИО);	
		
		НСДанныеЮЛ.СтруктураФИО = ФИОСтрокой; 
		
	ИначеЕсли ЭтоИП Тогда  
		
		НСДанныеЮЛ.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ИндивидуальныйПредприниматель;
		НСДанныеЮЛ.ОГРН      = ДанныеЮрЛица.Реквизиты.ИП.ОГРН;
		
		СтруктураФИО = Новый Структура;
		СтруктураФИО.Вставить("Фамилия",  ДанныеЮрЛица.ИП.Фамилия);
		СтруктураФИО.Вставить("Имя",      ДанныеЮрЛица.ИП.Имя);
		СтруктураФИО.Вставить("Отчество", ДанныеЮрЛица.ИП.Отчество);
		
		ФИОСтрокой = ЗначениеВСтрокуВнутр(СтруктураФИО);
				
		НСДанныеЮЛ.СтруктураФИО = ФИОСтрокой; 
				
	Иначе
		
		НСДанныеЮЛ.ЮрФизЛицо         = Перечисления.ЮрФизЛицо.ЮрЛицоНеРезидент;
		НСДанныеЮЛ.СтранаРегистрации = Справочники.СтраныМира.НайтиПоНаименованию(ДанныеЮрЛица.Реквизиты.ИностранноеЛицо.Страна);
		
	КонецЕсли;
	
	// Телефоны
	Для Каждого Телефон Из ДанныеЮрЛица.Контакты.Телефон Цикл 				
		
		НСТелефон = ОбъектДок.КонтактныеДанные.Добавить();
		НСТелефон.Роль     = Роль;
		НСТелефон.Тип      = Перечисления.ТипыКонтактнойИнформации.Телефон;
		НСТелефон.Значение = Телефон;	
		
	КонецЦикла;			 
	
	// Электронная почта
	Для Каждого ЭлПочта Из ДанныеЮрЛица.Контакты.ЭлектроннаяПочта Цикл 				
		
		НСЭПочта = ОбъектДок.КонтактныеДанные.Добавить();
		НСЭПочта.Роль     = Роль;
		НСЭПочта.Тип      = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
		НСЭПочта.Значение = ЭлПочта;	
		
	КонецЦикла;
	
КонецПроцедуры
	
Процедура ЗаполнениеДанныхПоВладельцуОбъекта(ОбъектДок, ИсходнаяСтруктура)
	
	 	// Владелец объекта погрузки	
	Если ИсходнаяСтруктура.ВладелецЭтоОтправитель Тогда 
		
		ОбъектДок.Владелец_Тип = Перечисления.Saby_ВладелецОбъектаОтгрузки.Отправитель;		
		// !!!
		// заполним данные отправителя в данных ГП
		
    ИначеЕсли ЗначениеЗаполнено(ИсходнаяСтруктура.НеизвестенПричина) Тогда 
		
	    ОбъектДок.Владелец_Тип               = Перечисления.Saby_ВладелецОбъектаОтгрузки.Неизвестен;		
		ОбъектДок.Владелец_НеизвестенПричина = ИсходнаяСтруктура.НеизвестенПричина;
				
	Иначе 	
		
		ОбъектДок.Владелец_Тип    = Перечисления.Saby_ВладелецОбъектаОтгрузки.ДругоеЮрЛицо;
		ОбъектДок.ВладелецОбъекта = ПолучитьЮрЛицо(ИсходнаяСтруктура.ВладелецОбъекта);
		
	КонецЕсли;
	// -

КонецПроцедуры

#КонецОбласти

Процедура ЗапонитьДанныеПогрузки(ОбъектДок, ИсходнаяСтруктура) 
	
	ОбъектДок.Перевозчик_ПриемкаДатаВремяПрибыл            = ИсходнаяСтруктура.ДатаВремяПрибытия;
	ОбъектДок.Перевозчик_ПриемкаДатаВремя                  = ИсходнаяСтруктура.ДатаВремяНачалаПогрузки;
	ОбъектДок.Перевозчик_ПриемкаДатаВремяУбыл              = ИсходнаяСтруктура.ДатаВремяУбытия;
	
	// Замечания
	ОбъектДок.Перевозчик_ПогрузкаЗамечанияПоСостояниюГруза = ИсходнаяСтруктура.ЗамечаниеСостояние;
	ОбъектДок.Перевозчик_ЗамечанияПоПогрузочнымРаботам     = ИсходнаяСтруктура.ЗамечаниеПоРаботам;
	ОбъектДок.Перевозчик_ПогрузкаЗамечанияПоКоличеству     = ИсходнаяСтруктура.ЗамечаниеКоличество;
	ОбъектДок.Перевозчик_ПогрузкаЗамечанияПоМассе          = ИсходнаяСтруктура.ЗамечаниеМасса;
			
КонецПроцедуры

Процедура ЗапонитьДанныеПриемки(ОбъектДок, ИсходнаяСтруктура)  
		
	ОбъектДок.Выгрузка_ДатаВремя         = ПрочитатьДатуJSON(ИсходнаяСтруктура.ДатаВремяПлан,     ФорматДатыJSON.ISO);
	ОбъектДок.Выгрузка_ДатаВремяПрибыл   = ПрочитатьДатуJSON(ИсходнаяСтруктура.ДатаВремяПрибытия, ФорматДатыJSON.ISO);
	ОбъектДок.Выгрузка_ДатаВремяУбыл     = ПрочитатьДатуJSON(ИсходнаяСтруктура.ДатаВремяУбытия,   ФорматДатыJSON.ISO);

	ОбъектДок.Выгрузка_Адрес             = ИсходнаяСтруктура.АдресВыгрузки;
	ОбъектДок.Выгрузка_Состояние         = ИсходнаяСтруктура.СостояниеОбщее;

	ОбъектДок.Приемка_Отказ              = ИсходнаяСтруктура.ОтказВПриемке;
	ОбъектДок.Приемка_ОтказПричина       = ИсходнаяСтруктура.ОтказВПриемкеПричина;

	ОбъектДок.Выгрузка_МассаБрутто       = ИсходнаяСтруктура.МассаБрутто;
	// !!!
	ОбъектДок.Выгрузка_МассаМетодРасчета = Перечисления.Saby_МетодОпределенияМассы[ИсходнаяСтруктура.МетодОпределения];
	ОбъектДок.Выгрузка_КоличествоМест    = ИсходнаяСтруктура.Количество;
			
КонецПроцедуры

Процедура ЗапонитьДанныеВыдачи(ОбъектДок, ИсходнаяСтруктура)
	
	ОбъектДок.Перевозчик_ВыгрузкаДатаВремяПрибыл = 
	ПрочитатьДатуJSON(ИсходнаяСтруктура.ДатаВремяПрибытия, ФорматДатыJSON.ISO);   
	
	ОбъектДок.Перевозчик_ВыгрузкаДатаВремя       = 
	ПрочитатьДатуJSON(ИсходнаяСтруктура.ДатаВремяНачалаПогрузки, ФорматДатыJSON.ISO); 
	
	ОбъектДок.Перевозчик_ВыгрузкаДатаВремяУбыл   = 
	ПрочитатьДатуJSON(ИсходнаяСтруктура.ДатаВремяУбытия, ФорматДатыJSON.ISO); 
	
	ОбъектДок.Выгрузка_Адрес = ИсходнаяСтруктура.АдресВыгрузки;
	
	// Состояние
	ОбъектДок.Перевозчик_ВыгрузкаЗамечанияПоСостояниюГруза = ИсходнаяСтруктура.ЗамечаниеСостояниеГруза;
	ОбъектДок.Перевозчик_ЗамечанияПоРазгрузочнымРаботам    = ИсходнаяСтруктура.ЗамечаниеПоРаботам;
		
КонецПроцедуры

Процедура ЗапонитьДанныеДокументаДоставки(ОбъектДок, ИсходнаяСтруктура)
	
	// на данный момент не используется
	// Переадресовка
	
	// Условия перевозки
	УсловияПеревозки = ИсходнаяСтруктура.УсловияПеревозки;
	
	ОбъектДок.Отправитель_ДоставитьДо   = ПрочитатьДатуJSON(УсловияПеревозки.ДатаВремяДоставки, ФорматДатыJSON.ISO);
	ОбъектДок.Отправитель_ДоставитьСрок = УсловияПеревозки.СрокДоставки;
	
	ОбъектДок.Отправитель_НормыПеревозки      = УсловияПеревозки.Нормы;
	ОбъектДок.Отправитель_ПерегрузкаЗапрешена = Не УсловияПеревозки.Перегрузка;
	ОбъектДок.Отправитель_Пломба              = УсловияПеревозки.Пломба;
	ОбъектДок.Отправитель_ОграничениеСкорости = УсловияПеревозки.Скорость;
	
	// Климатический режим	
	КлиматическийРежим = ИсходнаяСтруктура.КлиматическийРежим;
	
	ОбъектДок.Отправитель_ТемператураОт = КлиматическийРежим.ТемператураОт;
	ОбъектДок.Отправитель_ТемператураДо = КлиматическийРежим.ТемператураДо;
	
	ОбъектДок.Отправитель_ВлажностьОт   = КлиматическийРежим.ВлажностьОт;
	ОбъектДок.Отправитель_ВлажностьДо   = КлиматическийРежим.ВлажностьДо;
		
	// Погрузка	
	Погрузка = ИсходнаяСтруктура.Погрузка; 
	
	ОбъектДок.Погрузка_ДатаВремя         = ПрочитатьДатуJSON(Погрузка.ДатаВремяПодачи,   ФорматДатыJSON.ISO);
	ОбъектДок.Погрузка_ДатаВремяПрибыл   = ПрочитатьДатуJSON(Погрузка.ДатаВремяПрибытия, ФорматДатыJSON.ISO);
	ОбъектДок.Погрузка_ДатаВремяУбыл     = ПрочитатьДатуJSON(Погрузка.ДатаВремяУбытия,   ФорматДатыJSON.ISO);	
	ОбъектДок.Погрузка_Адрес             = Погрузка.Адрес.Адрес;
	
	ОбъектДок.Погрузка_КоличествоМест    = Погрузка.ГрузовыеМеста;
    ОбъектДок.Погрузка_Масса             = Погрузка.МассаБрутто;
	
	Если ЗначениеЗаполнено(Погрузка.ОпределениеМассы) Тогда 
		ОбъектДок.Погрузка_МассаМетодРасчета = Перечисления.Saby_МетодОпределенияМассы[Погрузка.ОпределениеМассы];
	КонецЕсли;
	
	// Состояние
	Массив = Новый Массив;
	Массив.Добавить(Погрузка.СостояниеТары);
	Массив.Добавить(Погрузка.СостояниеКузова);
	Массив.Добавить(Погрузка.СостояниеУпаковки);
	
	ОбъектДок.Погрузка_Состояние = СокрЛП(СтрСоединить(Массив, " ")); 
	
	// по умолчанию
	ОбъектДок.Отправитель_ИнициаторПереадресации = Перечисления.Saby_РолиКонтрагентовЭтрН.Отправитель;
	
	//ОбъектДок.Отправитель_ИнициаторПереадресации = 
	//Перечисления.Saby_ИнициаторПереадресации[ИсходнаяСтруктура.ИнициаторПереадресации];
	
	// ОснованиеДоступа ???
	ОбъектДок.Отгрузчик = ПолучитьЮрЛицо(Погрузка.ЛицоПогрузки);		
	ЗаполнитьДанныеЮрЛицИКонтактнуюИнформацию(
	    ОбъектДок,
	    Погрузка.ЛицоПогрузки, 
		Перечисления.Saby_РолиКонтрагентовЭтрН.Отгрузчик);
		                                                                        
	// по умолчанию
	ОбъектДок.Владелец_Тип = Перечисления.Saby_ВладелецОбъектаОтгрузки.Отправитель; 
				
КонецПроцедуры

#Область ЗагрузкаТСиВодители

Процедура ЗаполнитьДанныеТранспортаИВодителейДокумента(ОбъектДок, ИсходнаяСтруктура)
	
	// Водители
	Для Каждого ДанныеВодитель Из ИсходнаяСтруктура.Грузоперевозчик.Водители Цикл 
		
		НС = ОбъектДок.Водители.Добавить();
		НС.Водитель = РазборатьДанныеВодителей(ДанныеВодитель); 
		
	КонецЦикла;
	
	ДанныеВсехТС = ДанныеТСИПрицеповИзБазы(
		ИсходнаяСтруктура.Грузоперевозчик.ТранспортноеСредство, 
		ИсходнаяСтруктура.Грузоперевозчик.Прицепы);
	
	// ТС
	ОбъектДок.Отправитель_ТранспортноеСредство = 
	РазобратьДанныеТС(ИсходнаяСтруктура.Грузоперевозчик.ТранспортноеСредство, ДанныеВсехТС);
	
	// Прицепы
	Для Каждого Прицеп Из ИсходнаяСтруктура.Грузоперевозчик.Прицепы Цикл
				
        НС = ОбъектДок.Прицепы.Добавить();
		НС.Прицеп = РазобратьДанныеТС(Прицеп, ДанныеВсехТС, Истина);
		
	КонецЦикла;	
				
	// Спец разрешения
	Для Каждого Разрешение Из ИсходнаяСтруктура.Грузоперевозчик.СпецРазрешения Цикл
		
		НС = ОбъектДок.СпецРазрешения.Добавить();
		ЗаполнитьЗначенияСвойств(НС, Разрешение);
		
		НС.Дата = ПрочитатьДатуJSON(Разрешение.Дата, ФорматДатыJSON.ISO); 
		
	КонецЦикла;
	
КонецПроцедуры

// Документы Сбис....
Функция ДанныеТСИПрицеповИзБазы(ТС, Прицепы)
		
	Если ЗначениеЗаполнено(ТС) Тогда 
		Прицепы.Добавить(ТС);           
	КонецЕсли;
	
	Если Не Прицепы.Количество() Тогда 
		Возврат Новый ТаблицаЗначений;  
	КонецЕсли;
			
	МассивVIN = Новый Массив;
	МассивСТС = Новый Массив;
	МассивРН  = Новый Массив;
	
	Для Каждого Элемент Из Прицепы Цикл
		
		Если ЗначениеЗаполнено(Элемент.VIN) Тогда 
			МассивVIN.Добавить(Элемент.VIN);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Элемент.НомерСТС) Тогда 
			МассивСТС.Добавить(Элемент.НомерСТС);	
		КонецЕсли;
							
		МассивРН.Добавить(Элемент.РегНомер);			
					
	КонецЦикла;
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("МассивVIN", МассивVIN);
	Запрос.УстановитьПараметр("МассивСТС", МассивСТС);
	Запрос.УстановитьПараметр("МассивРН",  МассивРН);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТранспортныеСредства.Ссылка КАК Ссылка,
	|	ТранспортныеСредства.Код КАК РегНомер,
	|	ТранспортныеСредства.VIN КАК VIN,
	|	ТранспортныеСредства.НомерСТС КАК НомерСТС
	|ПОМЕСТИТЬ ВТ
	|ИЗ
	|	Справочник.ТранспортныеСредства КАК ТранспортныеСредства
	|ГДЕ
	|	ТранспортныеСредства.Код В(&МассивРН)
    |
	|ОБЪЕДИНИТЬ ВСЕ
    |
	|ВЫБРАТЬ
	|	ТранспортныеСредства.Ссылка,
	|	ТранспортныеСредства.Код,
	|	ТранспортныеСредства.VIN,
	|	ТранспортныеСредства.НомерСТС
	|ИЗ
	|	Справочник.ТранспортныеСредства КАК ТранспортныеСредства
	|ГДЕ
	|	ТранспортныеСредства.VIN В(&МассивVIN)
    |
	|ОБЪЕДИНИТЬ ВСЕ
    |
	|ВЫБРАТЬ
	|	ТранспортныеСредства.Ссылка,
	|	ТранспортныеСредства.Код,
	|	ТранспортныеСредства.VIN,
	|	ТранспортныеСредства.НомерСТС
	|ИЗ
	|	Справочник.ТранспортныеСредства КАК ТранспортныеСредства
	|ГДЕ
	|	ТранспортныеСредства.НомерСТС В(&МассивСТС)
	|;
    |
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ.Ссылка КАК Ссылка,
	|	МАКСИМУМ(ВТ.РегНомер) КАК РегНомер,
	|	МАКСИМУМ(ВТ.VIN) КАК VIN,
	|	МАКСИМУМ(ВТ.НомерСТС) КАК НомерСТС
	|ИЗ
	|	ВТ КАК ВТ
    |
	|СГРУППИРОВАТЬ ПО
	|   ВТ.Ссылка	";

	Результат = Запрос.Выполнить().Выгрузить();
	
	Результат.Индексы.Добавить("VIN");
	//Результат.Индексы.Добавить("НомерСТС");
	//Результат.Индексы.Добавить("РегНомер");
	
	Возврат Результат;
	
КонецФункции

// Разбор JSON по автомобилям и прицепам
//
Функция РазобратьДанныеТС(ТС, ДанныеВсехТС, ЭтоПрицеп = Ложь)
			
	// Поиск
    Ссылка = Неопределено;
	
	// 1. VIN
	Если ЗначениеЗаполнено(ТС.VIN) Тогда 
		
		Отбор = Новый Структура;
		Отбор.Вставить("VIN", ТС.VIN);
		
		НайденныеСтроки = ДанныеВсехТС.НайтиСтроки(Отбор);
		Если НайденныеСтроки.Количество() Тогда		
			Ссылка = НайденныеСтроки[0].Ссылка;		
		КонецЕсли;
		
	КонецЕсли;
			
	// 2. Попытка по Номер СТС
	Если ЗначениеЗаполнено(ТС.НомерСТС)
		И Не ЗначениеЗаполнено(Ссылка) Тогда 
		
		Отбор = Новый Структура;
		Отбор.Вставить("НомерСТС", ТС.НомерСТС);
		
		НайденныеСтроки = ДанныеВсехТС.НайтиСтроки(Отбор);
		Если НайденныеСтроки.Количество() Тогда		
			Ссылка = НайденныеСтроки[0].Ссылка;		
		КонецЕсли;
		
	КонецЕсли;
	
	// 3. Попытка по РегНомер
	Если Не ЗначениеЗаполнено(Ссылка) Тогда 
		
		Отбор = Новый Структура;
		Отбор.Вставить("РегНомер", ТС.РегНомер);
		
		НайденныеСтроки = ДанныеВсехТС.НайтиСтроки(Отбор);
		Если НайденныеСтроки.Количество() Тогда		
			Ссылка = НайденныеСтроки[0].Ссылка;		
		КонецЕсли; 
		
	КонецЕсли;	

	Если Не ЗначениеЗаполнено(Ссылка) Тогда 
		
		// Создадим новую запись в БД
		Ссылка = СоздатьНовоеТС(ТС, ЭтоПрицеп);
	
	КонецЕсли;
	
	Возврат Ссылка;	
		
КонецФункции 

Функция СоздатьНовоеТС(ТС, ЭтоПрицеп)
	
	УстановитьПривилегированныйРежим(Истина);
		
	ОбъектТС = Справочники.ТранспортныеСредства.СоздатьЭлемент();
	ЗаполнитьЗначенияСвойств(ОбъектТС, ТС);
		
	ОбъектТС.Код                          = ТС.РегНомер;
	ОбъектТС.Наименование                 = ТС.РегНомер;
	ОбъектТС.ТипВладения                  = Перечисления.Saby_ТипыВладенияТС[ТС.ТипВладения];
	ОбъектТС.ГрузоподъемностьВТоннах      = ТС.Грузоподъемность;
	ОбъектТС.ВместимостьВКубическихМетрах = ТС.Вместимость;
	
	Если ЭтоПрицеп Тогда 
		ОбъектТС.Вид = Перечисления.Saby_ВидыТС.Прицеп;
	Иначе
		ОбъектТС.Вид = Перечисления.Saby_ВидыТС.Автомобиль;
	КонецЕсли;
		
	Если ЗначениеЗаполнено(ТС.Тип) Тогда 
		
		СсылкаТипТС = Справочники.ТипыТранспортныхСредств.НайтиПоНаименованию(ТС.Тип);
		Если Не ЗначениеЗаполнено(СсылкаТипТС) Тогда 
			
			// Создадим новую запись
			ТипТС = Справочники.ТипыТранспортныхСредств.СоздатьЭлемент();
			ТипТС.Наименование = ТС.Тип;
			
			ТипТС.ОбменДанными.Загрузка = Истина;
			ТипТС.Записать();			
			
			СсылкаТипТС = ТипТС.Ссылка; 
			
		КонецЕсли;
		
		ОбъектТС.Тип = СсылкаТипТС; 
		
	КонецЕсли;	
	
	// Документы владения
	ТЗ = ТаблицаДокументовТрН();
	
	// Подготовка данных для поиска всех документов владения ТС 
	НомерСтроки = 0;
	Для Каждого ДокументВладения Из ТС.ОснованиеВладения Цикл
		
		НС = ТЗ.Добавить();
		Тип = Перечисления.Saby_ТипыДокумента.ПодтверждениеВладения;
		ЗаполнитьДанныеСтрокиТаблицыДокументовТрН(НС, ДокументВладения, Тип, НомерСтроки);
		
	КонецЦикла;
	
	// Получим ссылки на существующие и новые документы
	СоответствиеДокументов = НайтиСоздатьДокументТрН(ТЗ);
	
	// Заполняем данные
	Для Каждого СтрокаДок Из ТЗ Цикл 
		
		НС = ОбъектТС.ДокументыПодтверждающиеВладение.Добавить();
		НС.ДокументВладения = СоответствиеДокументов.Получить(СтрокаДок.НомерСтроки);
		
	КонецЦикла;
	
	ОбъектТС.ОбменДанными.Загрузка = Истина;
	ОбъектТС.Записать();
	
	Возврат ОбъектТС.Ссылка;
	
КонецФункции

Функция РазборатьДанныеВодителей(Водитель)
		
	Массив = Новый Массив;
	Массив.Добавить(Водитель.Фамилия);
	Массив.Добавить(Водитель.Имя);
	Массив.Добавить(Водитель.Отчество);
	
	Наименование = СтрСоединить(Массив, " ");
	
	// 1. По ИНН
	Если ЗначениеЗаполнено(Водитель.ИНН) Тогда  
		Ссылка = Справочники.ФизическиеЛица.НайтиПоРеквизиту("ИНН", Водитель.ИНН);
	Иначе
		Ссылка = Неопределено;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Ссылка) Тогда
		
		//ToDo: добавить поиск по номеру ВУ...
		//Отбор = Новый Структура;
		//Отбор.Вставить("ВидДокумента", Справочники.ВидыДокументовФизическихЛиц.ВодительскоеУдостоверение);
		//РегистрыСведений.ДокументыФизическихЛиц.Получить(ТекущаяДатаСеанса(), Отбор);
		//Номер
		//ДатаВыдачи
		
		// 2. ИНН может быть не заполнен. По наименованию
		Ссылка = Справочники.ФизическиеЛица.НайтиПоНаименованию(Наименование);
		Если Не ЗначениеЗаполнено(Ссылка) Тогда
			// Создадим водителя
			Ссылка = НовоеФизЛицо(Водитель, Наименование);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Ссылка;
	
КонецФункции

Функция НовоеФизЛицо(Данные, Наименование)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ОбъектВодитель = Справочники.ФизическиеЛица.СоздатьЭлемент();
	ОбъектВодитель.Наименование = Наименование;
	ЗаполнитьЗначенияСвойств(ОбъектВодитель, Данные);
	
	// Телефоны
	Для Каждого Телефон Из Данные.Телефон Цикл 
		
		НС = ОбъектВодитель.КонтактнаяИнформация.Добавить();
		НС.Тип           = Перечисления.ТипыКонтактнойИнформации.Телефон;
		НС.Вид           = Справочники.ВидыКонтактнойИнформации.ТелефонМобильныйФизическиеЛица;
		НС.Представление = Телефон;
		НС.НомерТелефона = Телефон;
		
	КонецЦикла;
	
	ОбъектВодитель.ОбменДанными.Загрузка = Истина;
	Ссылка = ОбъектВодитель.Записать();
	
	// ВУ	
	МенеджерЗаписи = РегистрыСведений.ДокументыФизическихЛиц.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Активность   = Истина;
	МенеджерЗаписи.Период       = ТекущаяДатаСеанса();
	МенеджерЗаписи.Физлицо      = Ссылка;
	МенеджерЗаписи.ВидДокумента = Справочники.ВидыДокументовФизическихЛиц.ВодительскоеУдостоверение;
	МенеджерЗаписи.Серия        = Данные.СерияВУ;
	МенеджерЗаписи.Номер        = Данные.НомерВУ;
	МенеджерЗаписи.ДатаВыдачи   = ПрочитатьДатуJSON(Данные.ДатаВыдачиВУ, ФорматДатыJSON.ISO);

	МенеджерЗаписи.Записать();
	
	Возврат Ссылка;
	
КонецФункции

#КонецОбласти

#Область ЗагрузкаДокументыТрН

Функция НайтиСоздатьДокументТрН(ТЗДокументы)
			
	НайденныеДокументы = НайтиДокументыТрН(ТЗДокументы);
	Для Каждого СтрокаДок Из ТЗДокументы Цикл 						
		
		Ссылка = НайденныеДокументы.Получить(СтрокаДок.НомерСтроки);
		Если Не ЗначениеЗаполнено(Ссылка) Тогда 
			НайденныеДокументы.Вставить(СтрокаДок.НомерСтроки, НовыйДокументТрН(СтрокаДок));
		КонецЕсли;
			
	КонецЦикла;	

	Возврат НайденныеДокументы;
	
КонецФункции

Функция ТаблицаДокументовТрН()
	
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("Номер",        Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(10, ДопустимаяДлина.Фиксированная)));
	ТЗ.Колонки.Добавить("Дата",         Новый ОписаниеТипов("Дата", , , Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	ТЗ.Колонки.Добавить("ТипДок",       Новый ОписаниеТипов("ПеречислениеСсылка.Saby_ТипыДокумента"));
	ТЗ.Колонки.Добавить("Наименование", Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(30, ДопустимаяДлина.Фиксированная))); 
	ТЗ.Колонки.Добавить("Стороны",      Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(0, ДопустимаяДлина.Переменная))); 	
	ТЗ.Колонки.Добавить("НомерСтроки",  Новый ОписаниеТипов("Число",    Новый КвалификаторыЧисла(5, 0, ДопустимыйЗнак.Любой)));
		
	Возврат ТЗ;
	
КонецФункции

Функция НайтиДокументыТрН(ТЗ)
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТЗ", ТЗ);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТЗ.Номер КАК Номер,
	|	ТЗ.Дата КАК Дата,
	|	ТЗ.ТипДок КАК ТипДок, 
	|	ТЗ.НомерСтроки КАК НомерСтроки
	|ПОМЕСТИТЬ ВТ
	|ИЗ
	|	&ТЗ КАК ТЗ
    |
	|ИНДЕКСИРОВАТЬ ПО
	|	Номер,
	|	Дата
	|;
    |
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ.Номер КАК Номер,
	|	ВТ.Дата КАК Дата,
	|	ВТ.ТипДок КАК Тип,
	|   ВТ.НомерСтроки КАК НомерСтроки,
	|	МАКСИМУМ(ЕСТЬNULL(Saby_ДокументыТрН.Ссылка, НЕОПРЕДЕЛЕНО)) КАК Ссылка
	|ИЗ
	|	ВТ КАК ВТ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Saby_ДокументыТрН КАК Saby_ДокументыТрН
	|		ПО ВТ.Номер = Saby_ДокументыТрН.Номер
	|			И ВТ.Дата = Saby_ДокументыТрН.Дата
	|			И ВТ.ТипДок = Saby_ДокументыТрН.Тип
    |
	|СГРУППИРОВАТЬ ПО
	|	ВТ.Номер,
	|	ВТ.Дата,
	|	ВТ.ТипДок,
	|   ВТ.НомерСтроки
	|";	

	Выборка = Запрос.Выполнить().Выбрать();
	
	Соответствие = Новый Соответствие;
	Пока Выборка.Следующий() Цикл 				
		Соответствие.Вставить(Выборка.НомерСтроки, Выборка.Ссылка);		
	КонецЦикла;
	
	Возврат Соответствие;
	
КонецФункции

Функция НовыйДокументТрН(Данные)
	
	УстановитьПривилегированныйРежим(Истина);
		
	ОбъектДокТрН = Справочники.Saby_ДокументыТрН.СоздатьЭлемент();
	ЗаполнитьЗначенияСвойств(ОбъектДокТрН, Данные);
	
	Стороны = ЗначениеИзСтрокиВнутр(Данные.Стороны);
	
	Для Каждого Сторона Из Стороны Цикл
		НС = ОбъектДокТрН.Стороны.Добавить();
		НС.Сторона = ПолучитьЮрЛицо(Сторона, Истина);		
	КонецЦикла;
	
	ОбъектДокТрН.ОбменДанными.Загрузка = Истина;
	
	Возврат ОбъектДокТрН.Ссылка;
	
КонецФункции

Процедура ЗаполнитьДанныеДокументовТрН(ОбъектДок, ДанныеДокументов)
	
	ТЗ = ТаблицаДокументовТрН();
	
	//РасчетПеревозки   = ДанныеДокументов.РасчетПеревозки;
	УслугиПеревозки   = ДанныеДокументов.УслугиПеревозки;
	СопровождениеТН   = ДанныеДокументов.СопровождениеТН; // массив
	Груз              = ДанныеДокументов.Груз;            // массив
	Отгрузка          = ДанныеДокументов.Отгрузка;        // массив
	СопроводВедомость = ДанныеДокументов.СопроводительнаяВедомость;
	
	// ToDo: когда-нибудь понадобится. Сделана заготовка в формате под будущий функционал... 
	// Расчет перевозки пока не нужен
	
	НомерСтроки = 0;
	
	// УслугиПеревозки
	Если ЗначениеЗаполнено(УслугиПеревозки) Тогда 
		НС = ТЗ.Добавить();	
		Тип = Перечисления.Saby_ТипыДокумента.ДоговорПеревозки;
		ЗаполнитьДанныеСтрокиТаблицыДокументовТрН(НС, УслугиПеревозки, Тип, НомерСтроки);
	КонецЕсли;
	
	// СопроводительнаяВедомость
	Если ЗначениеЗаполнено(СопроводВедомость) Тогда 
		НС = ТЗ.Добавить();
		Тип = Перечисления.Saby_ТипыДокумента.СопроводительнаяВедомость;
		ЗаполнитьДанныеСтрокиТаблицыДокументовТрН(НС, СопроводВедомость, Тип, НомерСтроки);
	КонецЕсли;
	
	// Груз	
	МассивДокументовТрНВТЗ(
		Груз, 
		ТЗ, 
		Перечисления.Saby_ТипыДокумента.КГрузу,
		НомерСтроки);

	
	// Отгрузка - Передача ценностей	
	МассивДокументовТрНВТЗ(
		Отгрузка, 
		ТЗ, 
		Перечисления.Saby_ТипыДокумента.ПередачиЦенностей,
		НомерСтроки);	
	
	// ТрН	
	МассивДокументовТрНВТЗ(
		СопровождениеТН, 
		ТЗ, 
		Перечисления.Saby_ТипыДокумента.КТранспортнойНакладной,
		НомерСтроки);	
	
	// За 1 раз
	// Получим ссылки на существующие и новые документы
	СоответствиеДокументов = НайтиСоздатьДокументТрН(ТЗ);
	
	// Заполняем данные по документам
	Для Каждого СтрокаДок Из ТЗ Цикл 
		
		СсылкаДок = СоответствиеДокументов.Получить(СтрокаДок.НомерСтроки);
				
		Если СтрокаДок.ТипДок = Перечисления.Saby_ТипыДокумента.ДоговорПеревозки Тогда 
			
			ОбъектДок.Заказчик_Договор = СсылкаДок; 			
		
		ИначеЕсли СтрокаДок.ТипДок = Перечисления.Saby_ТипыДокумента.СопроводительнаяВедомость Тогда 
			
			ОбъектДок.Отправитель_СопроводительнаяВедомость = СсылкаДок; 
			
		Иначе 	
			
			// кидаем все в общий список			
			НСДок = ОбъектДок.СопроводительныеДокументы.Добавить();
			НСДок.СопроводительныйДокумент = СсылкаДок;
			
		КонецЕсли;
					
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьДанныеСтрокиТаблицыДокументовТрН(Строка, Данные, Тип, НомерСтроки)
	
	НомерСтроки = НомерСтроки + 1;
	
	Строка.Наименование = СокрЛП(Данные.Наименование);
	Строка.Номер        = СокрЛП(Данные.НомерДокумента);
	Строка.Дата         = ПрочитатьДатуJSON(Данные.ДатаДокумента, ФорматДатыJSON.ISO);
	Строка.ТипДок       = Тип;
	Строка.Стороны      = ЗначениеВСтрокуВнутр(Данные.Стороны);
	Строка.НомерСтроки  = НомерСтроки;
	
КонецПроцедуры	

#КонецОбласти

// + Виды Упаковки

#Область ЗагрузкаГруза

Процедура ЗаполнитьДанныеПоГрузам(ОбъектДок, ДанныеГруз)
	
	//
	Если ЗначениеЗаполнено(ДанныеГруз.Стоимость.КодВалюты) Тогда 
		ОбъектДок.Валюта = Справочники.Валюты.НайтиПоКоду(ДанныеГруз.Стоимость.КодВалюты);
	КонецЕсли;
	
	МаксКлюч = 1;
	Для Каждого Груз Из ДанныеГруз.Позиция Цикл 
		
		НС = ОбъектДок.Грузы.Добавить();
		ЗаполнитьЗначенияСвойств(НС, Груз);
		
		НС.КлючСтроки     = МаксКлюч; 
		НС.Валюта         = ОбъектДок.Валюта; 
		НС.Стоимость      = Груз.СтоимостьСНалогом;
		НС.СпособУпаковки = Груз.Упаковка;
		
		Если ЗначениеЗаполнено(Груз.Тара) Тогда															
			НС.ВидТары = НайтиСоздатьВидУпаковки(Груз.Тара);  			
		КонецЕсли;		
		
		Если Груз.Контейнеры.Количество() Тогда 
			НС.Тип = Перечисления.Saby_ТипГруза.Контейнер;
		Иначе 
			НС.Тип = Перечисления.Saby_ТипГруза.Груз;
		КонецЕсли;
					
		// Контейнеры
		Для Каждого СтрокаКонт Из Груз.Контейнеры.Контейнер Цикл	
			
			НСКонт = ОбъектДок.Контейнеры.Добавить();
			ЗаполнитьЗначенияСвойств(НСКонт, СтрокаКонт);
			
			НСКонт.КлючСтроки_Грузы = МаксКлюч; 
			НСКонт.Количество       = 1; 
			
		КонецЦикла;		
			
		// Маркировки
		Для Каждого СтрокаМарк Из Груз.Маркировка Цикл
			
			НСМарк = ОбъектДок.Маркировки.Добавить();
			НСМарк.Значение         = СтрокаМарк.Значение; 
			НСМарк.КлючСтроки_Грузы = МаксКлюч;
			
		КонецЦикла;
				
		// Опасные грузы
		Для Каждого СтрокаОпасн Из Груз.ОпасныйГруз Цикл
			
			НСОпаснГр = ОбъектДок.ОпасныеГрузы.Добавить();
			НСОпаснГр.КлючСтроки_Грузы = МаксКлюч; 
							
		    НСОпаснГр.ОпасныйГруз = ОпасныйГруз(СтрокаОпасн);
							
		КонецЦикла;				
		
		// Сведения гос систем
		Для Каждого СтрокаГос Из Груз.СведенияГИС Цикл	
			
			НСГос = ОбъектДок.СведенияГосСистем.Добавить();
			
			НСГос.КлючСтроки_Грузы       = МаксКлюч;
			НСГос.НаименованиеГосСистемы = СтрокаГос.Наименование;
			НСГос.УчетнаяЕдиница         = СтрокаГос.УчетнаяЕдиница;
			НСГос.Идентификатор          = СтрокаГос.Идентификатор;
			НСГос.ИнаяИнформация         = СтрокаГос.ДругаяИнформация;
			
		КонецЦикла;	
		
		МаксКлюч = МаксКлюч + 1;
				
	КонецЦикла;
			
КонецПроцедуры

Функция НайтиСоздатьВидУпаковки(Код)
	
	СсылкаВидУпаковки = Справочники.Saby_ВидыУпаковки.НайтиПоКоду(Код);
	Если Не ЗначениеЗаполнено(СсылкаВидУпаковки) Тогда 		
		
		ОбъектВидУпаковки = Справочники.Saby_ВидыУпаковки.СоздатьЭлемент();
		ОбъектВидУпаковки.Код          = Код;
		ОбъектВидУпаковки.Наименование = Код;
		
		ОбъектВидУпаковки.ОбменДанными.Загрузка = Истина;
		ОбъектВидУпаковки.Записать();
		
		СсылкаВидУпаковки  = ОбъектВидУпаковки.Ссылка;
		
	КонецЕсли;
	
	Возврат СсылкаВидУпаковки;
	
КонецФункции
	
Функция ОпасныйГруз(СтрокаОпасн)
	
	// поиск существующей записи 
	СсылкаОГ = Справочники.Saby_ОпасныеГрузы.НайтиПоНаименованию(СтрокаОпасн.Наименование);
	Если Не ЗначениеЗаполнено(СсылкаОГ) Тогда 
		
		ОбъектОГ = Справочники.Saby_ОпасныеГрузы.СоздатьЭлемент();
		ЗаполнитьЗначенияСвойств(ОбъектОГ, СтрокаОпасн);
		
		Если ЗначениеЗаполнено(СтрокаОпасн.Класс) Тогда 
			ОбъектОГ.Класс = Перечисления.Saby_КлассыОпасностиГрузов[СтрокаОпасн.Класс];
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаОпасн.ГруппаУпаковки) Тогда 
			ОбъектОГ.ГруппаУпаковки = Перечисления.Saby_ГруппыУпаковки[СтрокаОпасн.ГруппаУпаковки];
		КонецЕсли;
				
		Если ЗначениеЗаполнено(СтрокаОпасн.ОграничениеТуннели) Тогда
			
			ОбъектОГ.ОграничениеПроездаЧерезТуннели = 
			Перечисления.Saby_КодыОграниченийПроездаЧерезТуннели[СтрокаОпасн.ОграничениеТуннели];
			
		КонецЕсли;
			
		ОбъектОГ.Записать();
		
		СсылкаОГ = ОбъектОГ.Ссылка;
		
	КонецЕсли;
	
	Возврат СсылкаОГ;
	
КонецФункции

#КонецОбласти

Процедура МассивДокументовТрНВТЗ(Массив, ТЗ, Тип, НомерСтроки)
	
	Для Каждого Док Из Массив Цикл  
		НС = ТЗ.Добавить();	
		ЗаполнитьДанныеСтрокиТаблицыДокументовТрН(НС, Док, Тип, НомерСтроки);
	КонецЦикла;

КонецПроцедуры

Процедура ЗаполнитьДанныеПоОтметкамДокумента(ОбъектДок, Отметки)
	
	// ToDo: Возможно понадобится фильтр по этапам... 
	
	МаксКлюч = 1;
	
	Для Каждого Отметка Из Отметки Цикл
		
		НС = ОбъектДок.Отметки.Добавить();
		
		НС.Описание   = Отметка.Описание;
		НС.ДатаВремя  = ПрочитатьДатуJSON(Отметка.ДатаВремя, ФорматДатыJSON.ISO);		
		НС.КлючСтроки = МаксКлюч;
		
		// Титул 2
		Если Отметка.Участник = "Т2" Тогда 
			
			НС.Этап = Перечисления.Saby_ТипТитулаЭтрН.ПолучениеГруза;
			НС.Роль = Перечисления.Saby_РолиКонтрагентовЭтрН.Перевозчик;
			
		ИначеЕсли Отметка.Участник = "Т3" Тогда
			
			// Титул 3
			НС.Этап = Перечисления.Saby_ТипТитулаЭтрН.ПриемкаГруза;
			НС.Роль = Перечисления.Saby_РолиКонтрагентовЭтрН.Получатель;
			
		ИначеЕсли Отметка.Участник = "Т4" Тогда	
			
			// Титул 4
			НС.Этап = Перечисления.Saby_ТипТитулаЭтрН.ВыдачаГруза;
			НС.Роль = Перечисления.Saby_РолиКонтрагентовЭтрН.Перевозчик;
			
		Иначе 
			
			// Титул 1
			НС.Этап = Перечисления.Saby_ТипТитулаЭтрН.Погрузка;
			НС.Роль = Перечисления.Saby_РолиКонтрагентовЭтрН.Отправитель;
			
		КонецЕсли;
		
		// Штрафы
		Для Каждого Штраф Из Отметка.Штрафы Цикл 
			
			НСШтраф = ОбъектДок.Штрафы.Добавить();
			ЗаполнитьЗначенияСвойств(НСШтраф, Штраф);
			
			НСШтраф.КлючСтроки_Отметки = МаксКлюч; 
			
		КонецЦикла;
				
		НомерСтроки = 0;
		
		ТЗ = ТаблицаДокументовТрН();
		
		// Акты взвешивания  		
		МассивДокументовТрНВТЗ(
			Отметка.АктыВзвешивания, 
			ТЗ, 
			Перечисления.Saby_ТипыДокумента.АктВзвешивания,
		    НомерСтроки);
		
		// Акты коммерческие
		МассивДокументовТрНВТЗ(
			Отметка.АктыКоммерческие, 
			ТЗ, 
			Перечисления.Saby_ТипыДокумента.АктКоммерческий,
		    НомерСтроки);
		
		// Получим ссылки на существующие и новые документы
		СоответствиеДокументов = НайтиСоздатьДокументТрН(ТЗ);
		
		// Заполняем данные по документам
		Для Каждого СтрокаДок Из ТЗ Цикл 
			
			СсылкаДок = СоответствиеДокументов.Получить(СтрокаДок.НомерСтроки);
			
			// кидаем все в общий список			
			НСДок = ОбъектДок.Акты.Добавить();
			НСДок.КлючСтроки_Отметки = МаксКлюч;
			НСДок.Документ           = СсылкаДок;
			
		КонецЦикла;
		
		МаксКлюч = МаксКлюч + 1;
		
	КонецЦикла;
		
КонецПроцедуры
 
#КонецОбласти    

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// В качестве параметр передается ссылка на справочник
// возвращаемое значение;
//Истина - если он справочник присоединенный создан в расширении иначе ложь  
Функция ПрисоединенныйФайлВРасширении(ПрисоединенныйФайл) Экспорт 
	
	Результат = Ложь;
	Для Каждого ЭлементТип Из Saby_РаботаСПрисоединеннымиФайламиПовтИсп.МассивТиповПрисоединенныхФайлов() Цикл
		Если ТипЗнч(ПрисоединенныйФайл) = ЭлементТип Тогда
			Результат = Истина;
		КонецЕсли;
	КонецЦикла;   
	
	Возврат Результат;
	
КонецФункции 

// Преобразует строку таблицы значений в структуру.
// Свойства структуры и их значения совпадают с колонками переданной строки.
//
// Параметры:
//  СтрокаТаблицыЗначений - СтрокаТаблицыЗначений
//
// Возвращаемое значение:
//  Структура - преобразованная строка таблицы значений.
//
Функция СтрокаТаблицыЗначенийВСтруктуру(СтрокаТаблицыЗначений, МассивКолонокИсключений = Неопределено) Экспорт
	
	Структура = Новый Структура;
	Для каждого Колонка Из СтрокаТаблицыЗначений.Владелец().Колонки Цикл 
		
		Если МассивКолонокИсключений <> Неопределено Тогда
			
			Если МассивКолонокИсключений.Найти(Колонка.Имя) = Неопределено Тогда 
				Структура.Вставить(Колонка.Имя, СтрокаТаблицыЗначений[Колонка.Имя]);
			КонецЕсли;			
				
		Иначе 	
			Структура.Вставить(Колонка.Имя, СтрокаТаблицыЗначений[Колонка.Имя]);
		КонецЕсли;
	
	КонецЦикла;
	
	Возврат Структура;
	
КонецФункции

Процедура УдалитьСвойстваИзСтруктуры(Структура, Массив)
	
	Для Каждого ЭлементМассива Из Массив Цикл
		Структура.Удалить(ЭлементМассива);	
	КонецЦикла;
		
КонецПроцедуры

Функция ЗначениеМетодаОпределенияМассы(ЗначениеПеречисления)
	
	Если ЗначениеПеречисления = Перечисления.Saby_МетодОпределенияМассы.ВзвешиваниеПоосно Тогда 
		Значение = "ВзвешиваниеПоосно";	
	ИначеЕсли ЗначениеПеречисления = Перечисления.Saby_МетодОпределенияМассы.Расчетный Тогда 
		Значение = "Расчетный";	
	Иначе 	
		Значение = "ВзвешиваниеПоОбщейМассе";	
	КонецЕсли;
	
	Возврат Значение;
	
КонецФункции

Функция ЗначениеОграниченияТуннели(ЗначениеПеречисления)
	
	Если Не ЗначениеЗаполнено(ЗначениеПеречисления) Тогда 
		Возврат "";
	КонецЕсли;
		
	Соответствие = Новый Соответствие;
	Соответствие.Вставить(Перечисления.Saby_КодыОграниченийПроездаЧерезТуннели.B,      "B");
	Соответствие.Вставить(Перечисления.Saby_КодыОграниченийПроездаЧерезТуннели.B1000C, "B1000C");
	Соответствие.Вставить(Перечисления.Saby_КодыОграниченийПроездаЧерезТуннели.B_D,    "B_D");
	Соответствие.Вставить(Перечисления.Saby_КодыОграниченийПроездаЧерезТуннели.B_E,    "B_E");
	Соответствие.Вставить(Перечисления.Saby_КодыОграниченийПроездаЧерезТуннели.C,      "C");
	Соответствие.Вставить(Перечисления.Saby_КодыОграниченийПроездаЧерезТуннели.C5000D, "C5000D");
	Соответствие.Вставить(Перечисления.Saby_КодыОграниченийПроездаЧерезТуннели.C_D,    "C_D");
	Соответствие.Вставить(Перечисления.Saby_КодыОграниченийПроездаЧерезТуннели.C_E,    "C_E");
	Соответствие.Вставить(Перечисления.Saby_КодыОграниченийПроездаЧерезТуннели.D,      "D");
	Соответствие.Вставить(Перечисления.Saby_КодыОграниченийПроездаЧерезТуннели.D_E,    "D_E");
	Соответствие.Вставить(Перечисления.Saby_КодыОграниченийПроездаЧерезТуннели.E,      "E");

	Возврат Соответствие.Получить(ЗначениеПеречисления);
	
КонецФункции

